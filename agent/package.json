{
  "name": "symbio-agent",
  "version": "0.1.0-beta.1",
  "private": true,
  "type": "module",
  "description": "Read-only Symbio host collector and monitoring agent.",
  "scripts": {
    "start": "node src/index.js",
    "postinstall": "cd node_modules/sqlite3 && ../.bin/node-gyp rebuild",
