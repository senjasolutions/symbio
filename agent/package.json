    "test": "node --test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "hono": "^4.10.6",
    "mysql2": "^3.22.6",
    "pg": "^8.22.0",
    "pm2": "^7.0.3",
    "sequelize": "^6.37.7",
    "sqlite3": "^6.0.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
