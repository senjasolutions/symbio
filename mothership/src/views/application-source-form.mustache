<!-- Application source directory stores a shortcut into the read-only file manager. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">{{#t}}nav.applications{{/t}}</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}">{{application.displayName}}</a></li><li class="breadcrumb-item active">{{#editing}}{{#t}}application.source.form.editTitle{{/t}}{{/editing}}{{^editing}}{{#t}}application.source.form.addTitle{{/t}}{{/editing}}</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-folder-open me-1" aria-hidden="true"></i>{{#editing}}{{#t}}application.source.form.editTitle{{/t}}{{/editing}}{{^editing}}{{#t}}application.source.form.addTitle{{/t}}{{/editing}}</h1>
{{#error}}<div class="alert alert-danger" role="alert">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#editing}}/applications/{{application.id}}/sources/{{source.id}}/edit{{/editing}}{{^editing}}/applications/{{application.id}}/sources{{/editing}}">
  <div class="card-body">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label" for="displayName">{{#t}}application.source.form.sourceName{{/t}}</label>
        <input class="form-control" id="displayName" name="displayName" maxlength="120" value="{{source.displayName}}" placeholder="{{#t}}application.source.form.namePlaceholder{{/t}}" required>
      </div>
      <div class="col-12">
        <label class="form-label" for="sourcePath">{{#t}}application.source.form.pathLabel{{/t}}</label>
        <input class="form-control font-monospace" id="sourcePath" name="sourcePath" value="{{source.sourcePath}}" placeholder="{{#t}}application.source.form.pathPlaceholder{{/t}}" required>
        <div class="form-text">{{#t}}application.source.form.pathHelp{{/t}}</div>
      </div>
    </div>
  </div>
  <div class="card-footer">
    <button class="btn btn-primary" type="submit">{{#t}}application.source.form.saveBtn{{/t}}</button>
    <a class="btn btn-outline-secondary" href="/applications/{{application.id}}">{{#t}}application.source.form.cancelBtn{{/t}}</a>
  </div>
</form>
