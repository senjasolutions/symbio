<!-- Application source directory stores a shortcut into the read-only file manager. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">Applications</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}">{{application.displayName}}</a></li><li class="breadcrumb-item active">{{#editing}}Edit Source Directory{{/editing}}{{^editing}}Add Source Directory{{/editing}}</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-folder-open me-1" aria-hidden="true"></i>{{#editing}}Edit Source Directory{{/editing}}{{^editing}}Add Source Directory{{/editing}}</h1>
{{#error}}<div class="alert alert-danger" role="alert">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#editing}}/applications/{{application.id}}/sources/{{source.id}}/edit{{/editing}}{{^editing}}/applications/{{application.id}}/sources{{/editing}}">
  <div class="card-body">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label" for="displayName">Source name</label>
        <input class="form-control" id="displayName" name="displayName" maxlength="120" value="{{source.displayName}}" placeholder="Application root" required>
      </div>
      <div class="col-12">
        <label class="form-label" for="sourcePath">Absolute host directory path</label>
        <input class="form-control font-monospace" id="sourcePath" name="sourcePath" value="{{source.sourcePath}}" placeholder="/home/username/my-application" required>
        <div class="form-text">Only this registered directory can be opened. Traversal, symlinks, and shell access are rejected.</div>
      </div>
    </div>
  </div>
  <div class="card-footer">
    <button class="btn btn-primary" type="submit">Save source directory</button>
    <a class="btn btn-outline-secondary" href="/applications/{{application.id}}">Cancel</a>
  </div>
</form>
