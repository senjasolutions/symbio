<!-- Create/edit user form. Superadmin-protected: only admin role can be assigned. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/settings?tab=users">{{#t}}nav.settings{{/t}}</a></li><li class="breadcrumb-item"><a href="/settings?tab=users">{{#t}}settings.users{{/t}}</a></li><li class="breadcrumb-item active">{{#isEdit}}{{#t}}common.edit{{/t}}{{/isEdit}}{{^isEdit}}{{#t}}common.add{{/t}}{{/isEdit}}</li></ol></nav>
<h1 class="h3 mb-3">{{#isEdit}}{{#t}}user.form.editTitle{{/t}}{{/isEdit}}{{^isEdit}}{{#t}}user.form.createTitle{{/t}}{{/isEdit}}</h1>
{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#isEdit}}/settings/users/{{user.id}}/edit{{/isEdit}}{{^isEdit}}/settings/users/create{{/isEdit}}"><div class="card-body">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  {{#isEdit}}<input type="hidden" name="id" value="{{user.id}}">{{/isEdit}}
  <div class="row g-3">
    <div class="col-md-6"><label class="form-label" for="username">{{#t}}user.form.username{{/t}}</label><input class="form-control" id="username" name="username" value="{{user.username}}" required {{#isEdit}}readonly{{/isEdit}}></div>
    <div class="col-md-6"><label class="form-label" for="email">{{#t}}user.form.email{{/t}}</label><input class="form-control" id="email" name="email" type="email" value="{{user.email}}" required></div>
    <div class="col-md-6"><label class="form-label" for="displayName">{{#t}}user.form.displayName{{/t}}</label><input class="form-control" id="displayName" name="displayName" value="{{user.displayName}}" required></div>
    <div class="col-md-6"><label class="form-label" for="password">{{#t}}user.form.password{{/t}} {{#isEdit}}<small class="text-secondary">({{#t}}user.form.passwordHelp{{/t}})</small>{{/isEdit}}</label><input class="form-control" id="password" name="password" type="password" value="" {{^isEdit}}required{{/isEdit}} autocomplete="new-password"></div>
  </div>
  <div class="mt-3"><p class="form-text">{{#t}}user.form.roleInfo{{/t}}</p></div>
</div><div class="card-footer d-flex gap-2"><button class="btn btn-primary" type="submit"><i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i> {{#isEdit}}{{#t}}user.form.save{{/t}}{{/isEdit}}{{^isEdit}}{{#t}}user.form.create{{/t}}{{/isEdit}}</button> <a class="btn btn-outline-secondary" href="/settings?tab=users">{{#t}}user.form.cancel{{/t}}</a></div></form>
