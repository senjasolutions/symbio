<!-- Search results page for server/service/symbio logs. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}/monitoring/logs/{{category}}">{{listTitle}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}/monitoring/logs/{{category}}/view?source={{log.slug}}">{{log.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}application.log.search.title{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-start mb-3"><div><h1 class="h3 mb-1">{{#t}}application.log.search.title{{/t}}</h1><p class="text-secondary mb-0"><strong>{{log.displayName}}</strong> · {{#t}}application.log.search.query{{/t}}: <code>{{query}}</code></p></div><a class="btn btn-outline-secondary btn-sm" href="/servers/{{server.id}}/monitoring/logs/{{category}}/view?source={{log.slug}}">{{#t}}application.log.search.backToViewer{{/t}}</a></div>
{{#error}}<div class="alert alert-danger" role="alert">{{error}}</div>{{/error}}
{{#logContent}}<pre class="log-output" tabindex="0">{{logContent}}</pre><p class="text-secondary small mb-0">{{bytes}} {{#t}}common.bytes{{/t}}{{#truncated}} · {{#t}}application.log.search.truncated{{/t}}{{/truncated}}</p>{{/logContent}}
{{^logContent}}{{^error}}<p class="text-muted">{{#t}}application.log.search.noResults{{/t}}</p>{{/error}}{{/logContent}}
