<!-- Application detail combines lifecycle controls, response chart, logs, source directories, and recent checks. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">Applications</a></li><li class="breadcrumb-item active">{{application.displayName}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-start mb-3"><div><h1 class="h3 mb-1">{{application.displayName}}</h1><p class="mb-1"><code>{{application.healthCheckUrl}}</code></p><div>{{#tags}}<span class="badge text-bg-secondary me-1">{{name}}</span>{{/tags}}</div></div><div>{{#latest}}<span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span>{{/latest}} {{^deleted}}<a class="btn btn-outline-primary btn-sm" href="/applications/{{application.id}}/edit">Edit</a>{{/deleted}}</div></div>
{{#deleted}}<div class="alert alert-secondary">This application is deleted and no longer checked.<form class="d-inline" method="post" action="/applications/{{application.id}}/restore"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-sm btn-primary ms-2" type="submit">Restore</button></form></div>{{/deleted}}
{{^deleted}}<form class="mb-3" method="post" action="/applications/{{application.id}}/delete" data-confirm="Stop monitoring and delete this application?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-outline-danger btn-sm" type="submit">Delete application</button></form>{{/deleted}}
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">24 hours</a><a class="btn btn-outline-primary" href="?range=7d">7 days</a></div>
<div class="mb-4">{{{responseChart}}}</div>
<section class="card mb-4"><div class="card-header d-flex justify-content-between align-items-center"><strong><i class="fa-solid fa-file-lines me-1" aria-hidden="true"></i>Application Logs</strong>{{^deleted}}<a class="btn btn-primary btn-sm" href="/applications/{{application.id}}/logs/new"><i class="fa-solid fa-plus" aria-hidden="true"></i> Add Log</a>{{/deleted}}</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Log source</th><th>Registered host path</th><th>Default tail</th><th></th></tr></thead><tbody>{{#logs}}<tr><td>{{displayName}}</td><td><code>{{filePath}}</code></td><td>{{tailLines}} lines</td><td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/applications/{{application.id}}/logs/{{id}}">View</a>{{^deleted}} <a class="btn btn-outline-secondary btn-sm" href="/applications/{{application.id}}/logs/{{id}}/edit">Edit</a>{{/deleted}}</td></tr>{{/logs}}{{^logs}}<tr><td colspan="4">No log sources are registered for this application.</td></tr>{{/logs}}</tbody></table></div></section>
<section class="card mb-4"><div class="card-header d-flex justify-content-between align-items-center"><strong><i class="fa-solid fa-folder-open me-1" aria-hidden="true"></i>Source Directories</strong>{{^deleted}}<a class="btn btn-primary btn-sm" href="/applications/{{application.id}}/sources/new"><i class="fa-solid fa-plus" aria-hidden="true"></i> Add Source</a>{{/deleted}}</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Source name</th><th>Registered directory</th><th></th></tr></thead><tbody>{{#sources}}<tr><td>{{displayName}}</td><td><code>{{sourcePath}}</code></td><td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/servers/{{application.serverId}}/file-manager?path={{sourcePath}}">Browse</a>{{^deleted}} <a class="btn btn-outline-secondary btn-sm" href="/applications/{{application.id}}/sources/{{id}}/edit">Edit</a>{{/deleted}}</td></tr>{{/sources}}{{^sources}}<tr><td colspan="3">No source directories are registered for this application.</td></tr>{{/sources}}</tbody></table></div></section>
<section class="card"><div class="card-header"><strong>Recent checks</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Observed</th><th>Status</th><th>HTTP</th><th>Response</th><th>Failure</th></tr></thead><tbody>{{#recent}}<tr><td>{{observedAtLabel}}</td><td><span class="badge text-bg-{{statusClass}}">{{status}}</span></td><td>{{statusCode}}</td><td>{{responseTimeLabel}}</td><td>{{failureReason}}</td></tr>{{/recent}}{{^recent}}<tr><td colspan="5">No checks received.</td></tr>{{/recent}}</tbody></table></div></section>
