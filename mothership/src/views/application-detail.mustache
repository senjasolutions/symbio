<!-- Application detail combines lifecycle controls, response chart, logs, source directories, and recent checks. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">{{#t}}nav.applications{{/t}}</a></li><li class="breadcrumb-item active">{{application.displayName}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-start mb-3"><div><h1 class="h3 mb-1">{{application.displayName}}</h1><p class="mb-1"><code>{{application.healthCheckUrl}}</code></p><div>{{#tags}}<span class="badge text-bg-secondary me-1">{{name}}</span>{{/tags}}</div></div><div>{{#latest}}<span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span>{{/latest}} {{^deleted}}<a class="btn btn-outline-primary btn-sm" href="/applications/{{application.id}}/edit">{{#t}}application.detail.edit{{/t}}</a>{{/deleted}}</div></div>
{{#deleted}}<div class="alert alert-secondary">{{#t}}application.detail.deletedMessage{{/t}}<form class="d-inline" method="post" action="/applications/{{application.id}}/restore"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-sm btn-primary ms-2" type="submit">{{#t}}application.detail.restore{{/t}}</button></form></div>{{/deleted}}
{{^deleted}}<form class="mb-3" method="post" action="/applications/{{application.id}}/delete" data-confirm="{{#t}}application.detail.deleteConfirm{{/t}}"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-outline-danger btn-sm" type="submit">{{#t}}application.detail.deleteBtn{{/t}}</button></form>{{/deleted}}
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">{{#t}}application.detail.range24h{{/t}}</a><a class="btn btn-outline-primary" href="?range=7d">{{#t}}application.detail.range7d{{/t}}</a></div>
<div class="mb-4">{{{responseChart}}}</div>
<section class="card mb-4"><div class="card-header d-flex justify-content-between align-items-center"><strong><i class="fa-solid fa-file-lines me-1" aria-hidden="true"></i>{{#t}}application.detail.logs{{/t}}</strong>{{^deleted}}<a class="btn btn-primary btn-sm" href="/applications/{{application.id}}/logs/new"><i class="fa-solid fa-plus" aria-hidden="true"></i> {{#t}}application.detail.addLog{{/t}}</a>{{/deleted}}</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}application.detail.logSource{{/t}}</th><th>{{#t}}application.detail.logPath{{/t}}</th><th>{{#t}}application.detail.defaultTail{{/t}}</th><th></th></tr></thead><tbody>{{#logs}}<tr><td>{{displayName}}</td><td><code>{{filePath}}</code></td><td>{{#t}}application.detail.tailLines{{/t}}</td><td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/applications/{{application.id}}/logs/{{id}}">{{#t}}application.detail.view{{/t}}</a>{{^deleted}} <a class="btn btn-outline-secondary btn-sm" href="/applications/{{application.id}}/logs/{{id}}/edit">{{#t}}application.detail.edit{{/t}}</a>{{/deleted}}</td></tr>{{/logs}}{{^logs}}<tr><td colspan="4">{{#t}}application.detail.noLogs{{/t}}</td></tr>{{/logs}}</tbody></table></div></section>
<section class="card mb-4"><div class="card-header d-flex justify-content-between align-items-center"><strong><i class="fa-solid fa-folder-open me-1" aria-hidden="true"></i>{{#t}}application.detail.sources{{/t}}</strong>{{^deleted}}<a class="btn btn-primary btn-sm" href="/applications/{{application.id}}/sources/new"><i class="fa-solid fa-plus" aria-hidden="true"></i> {{#t}}application.detail.addSource{{/t}}</a>{{/deleted}}</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}application.detail.sourceName{{/t}}</th><th>{{#t}}application.detail.sourceColumn{{/t}}</th><th></th></tr></thead><tbody>{{#sources}}<tr><td>{{displayName}}</td><td><code>{{sourcePath}}</code></td><td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/servers/{{application.serverId}}/file-manager?path={{sourcePath}}">{{#t}}application.detail.browse{{/t}}</a>{{^deleted}} <a class="btn btn-outline-secondary btn-sm" href="/applications/{{application.id}}/sources/{{id}}/edit">{{#t}}application.detail.edit{{/t}}</a>{{/deleted}}</td></tr>{{/sources}}{{^sources}}<tr><td colspan="3">{{#t}}application.detail.noSources{{/t}}</td></tr>{{/sources}}</tbody></table></div></section>
<section class="card"><div class="card-header"><strong>{{#t}}application.detail.recentChecks{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}application.detail.observed{{/t}}</th><th>{{#t}}applications.status{{/t}}</th><th>{{#t}}application.detail.http{{/t}}</th><th>{{#t}}applications.response{{/t}}</th><th>{{#t}}application.detail.failure{{/t}}</th></tr></thead><tbody>{{#recent}}<tr><td>{{observedAtLabel}}</td><td><span class="badge text-bg-{{statusClass}}">{{status}}</span></td><td>{{statusCode}}</td><td>{{responseTimeLabel}}</td><td>{{failureReason}}</td></tr>{{/recent}}{{^recent}}<tr><td colspan="5">{{#t}}application.detail.noChecks{{/t}}</td></tr>{{/recent}}</tbody></table></div></section>
