<!-- AI History — tabs for Skill Runs and AI Chat, both with pagination and filters. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/ai">{{#t}}ai.symbioIntelligence{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}ai.history{{/t}}</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-clock-rotate-left me-1" aria-hidden="true"></i>{{#t}}ai.history{{/t}}</h1>

<!-- Tabs -->
<ul class="nav nav-tabs mb-3">
  <li class="nav-item"><a class="nav-link {{#tabRuns}}active{{/tabRuns}}" href="/ai/history?tab=runs{{#skillFilter}}&skill={{skillFilter}}{{/skillFilter}}{{#statusFilter}}&status={{statusFilter}}{{/statusFilter}}{{#hasErrorFilter}}&hasError=1{{/hasErrorFilter}}"><i class="fa-solid fa-microchip me-1"></i>{{#t}}ai.skillRuns{{/t}}</a></li>
  <li class="nav-item"><a class="nav-link {{#tabChat}}active{{/tabChat}}" href="/ai/history?tab=chat"><i class="fa-solid fa-comment me-1"></i>{{#t}}ai.aiChat{{/t}}</a></li>
</ul>

{{#tabRuns}}
<!-- Skill Runs Tab -->
<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
  <form class="d-flex gap-2 align-items-center flex-wrap" method="get" action="/ai/history">
    <input type="hidden" name="tab" value="runs">
    <select class="form-select form-select-sm" name="skill" style="max-width:150px;" onchange="this.form.submit()">
      <option value="">{{#t}}ai.allSkills{{/t}}</option>
      {{#skillOptions}}
      <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
      {{/skillOptions}}
    </select>
    <select class="form-select form-select-sm" name="status" style="max-width:120px;" onchange="this.form.submit()">
      <option value="">{{#t}}ai.allStatus{{/t}}</option>
      <option value="running"{{#statusRunning}} selected{{/statusRunning}}>{{#t}}ai.running{{/t}}</option>
      <option value="completed"{{#statusCompleted}} selected{{/statusCompleted}}>{{#t}}ai.completed{{/t}}</option>
      <option value="failed"{{#statusFailed}} selected{{/statusFailed}}>{{#t}}ai.failed{{/t}}</option>
      <option value="cancelled"{{#statusCancelled}} selected{{/statusCancelled}}>Cancelled</option>
    </select>
    <div class="form-check">
      <input class="form-check-input" type="checkbox" id="hasError" name="hasError" value="1"{{#hasErrorFilter}} checked{{/hasErrorFilter}} onchange="this.form.submit()">
      <label class="form-check-label" for="hasError">{{#t}}ai.onlyErrors{{/t}}</label>
    </div>
    <button type="submit" class="btn btn-outline-primary btn-sm">{{#t}}common.filter{{/t}}</button>
  </form>
  <span class="text-secondary small">{{#t}}ai.showing{{/t}} {{offset}}-{{limit}} {{#t}}ai.of{{/t}} {{totalItems}}</span>
</div>

<section class="card">
  <div class="table-responsive">
    <table class="table table-sm mb-0">
      <thead>
        <tr>
          <th>{{#t}}common.date{{/t}}</th>
          <th>{{#t}}ai.skill{{/t}}</th>
          <th>{{#t}}ai.trigger{{/t}}</th>
          <th>{{#t}}ai.status{{/t}}</th>
          <th>{{#t}}ai.summary{{/t}}</th>
          <th>{{#t}}ai.duration{{/t}}</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#runs}}
        <tr class="{{#isFailed}}table-danger{{/isFailed}}">
          <td class="small" style="white-space:nowrap;">{{startedAt}}</td>
          <td class="small"><strong>{{skillName}}</strong></td>
          <td class="small">{{trigger}}</td>
          <td><span class="badge {{statusBadge}}">{{statusLabel}}</span></td>
          <td class="small" style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{summary}}">{{summary}}</td>
          <td class="small">{{duration}}</td>
          <td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/ai/skill-run/{{id}}">{{#t}}application.detail.view{{/t}}</a></td>
        </tr>
        {{/runs}}
        {{^runs}}
        <tr><td colspan="7" class="text-muted">{{#t}}ai.noRuns{{/t}}</td></tr>
        {{/runs}}
      </tbody>
    </table>
  </div>
</section>
{{/tabRuns}}

{{#tabChat}}
<!-- AI Chat Tab -->
<div class="d-flex justify-content-between align-items-center mb-2">
  <span class="text-secondary small">{{#t}}ai.showing{{/t}} {{offset}}-{{limit}} {{#t}}ai.of{{/t}} {{totalItems}}</span>
  <form class="d-inline" method="post" action="/ai/history/clear" onsubmit="return confirm('{{#t}}ai.clearConfirm{{/t}}')">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <button class="btn btn-outline-danger btn-sm" type="submit"><i class="fa-solid fa-trash me-1"></i>{{#t}}ai.clearAll{{/t}}</button>
  </form>
</div>

<section class="card">
  <div class="table-responsive">
    <table class="table table-sm mb-0">
      <thead>
        <tr>
          <th>{{#t}}common.date{{/t}}</th>
          <th>{{#t}}ai.tableQuestion{{/t}}</th>
          <th>{{#t}}ai.model{{/t}}</th>
          <th class="text-end">{{#t}}ai.tokensUsed{{/t}}</th>
          <th class="text-end">{{#t}}common.duration{{/t}}</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#chatEntries}}
        <tr class="{{^success}}table-danger{{/success}}">
          <td class="small" style="white-space:nowrap;">{{createdAt}}</td>
          <td>{{question}}</td>
          <td class="small">{{#modelLogo}}<img src="{{modelLogo}}" style="width:14px;height:14px;vertical-align:middle;margin-right:3px;">{{/modelLogo}}{{model}}</td>
          <td class="text-end">{{tokenTotal}}</td>
          <td class="text-end small">{{responseTimeMs}}ms</td>
          <td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/ai/history/{{id}}">{{#t}}application.detail.view{{/t}}</a></td>
        </tr>
        {{/chatEntries}}
        {{^chatEntries}}
        <tr><td colspan="6" class="text-muted">{{#t}}ai.noHistory{{/t}}</td></tr>
        {{/chatEntries}}
      </tbody>
    </table>
  </div>
</section>
{{/tabChat}}

<!-- Pagination (shared) -->
{{#pagination.length}}
<nav class="mt-2"><ul class="pagination pagination-sm justify-content-center">
  {{#prevPage}}<li class="page-item"><a class="page-link" href="?tab={{currentTab}}&page={{prevPage}}{{#skillFilter}}&skill={{skillFilter}}{{/skillFilter}}{{#statusFilter}}&status={{statusFilter}}{{/statusFilter}}{{#hasErrorFilter}}&hasError=1{{/hasErrorFilter}}">&laquo;</a></li>{{/prevPage}}
  {{#pagination}}
  <li class="page-item {{#active}}active{{/active}}"><a class="page-link" href="?tab={{currentTab}}&page={{page}}{{#skillFilter}}&skill={{skillFilter}}{{/skillFilter}}{{#statusFilter}}&status={{statusFilter}}{{/statusFilter}}{{#hasErrorFilter}}&hasError=1{{/hasErrorFilter}}">{{page}}</a></li>
  {{/pagination}}
  {{#nextPage}}<li class="page-item"><a class="page-link" href="?tab={{currentTab}}&page={{nextPage}}{{#skillFilter}}&skill={{skillFilter}}{{/skillFilter}}{{#statusFilter}}&status={{statusFilter}}{{/statusFilter}}{{#hasErrorFilter}}&hasError=1{{/hasErrorFilter}}">&raquo;</a></li>{{/nextPage}}
</ul></nav>
{{/pagination.length}}

<div class="mt-2">
  <a class="btn btn-outline-secondary btn-sm" href="/ai/command-center">&larr; {{#t}}ai.commandCenter{{/t}}</a>
</div>
