<!-- Shared application form keeps health defaults and inline tags consistent. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">{{#t}}nav.applications{{/t}}</a></li><li class="breadcrumb-item active">{{#editing}}{{#t}}common.edit{{/t}}{{/editing}}{{^editing}}{{#t}}common.add{{/t}}{{/editing}}</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-window-maximize me-1" aria-hidden="true"></i>{{#editing}}{{#t}}application.form.editTitle{{/t}}{{/editing}}{{^editing}}{{#t}}application.form.addTitle{{/t}}{{/editing}}</h1>
{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#editing}}/applications/{{application.id}}/edit{{/editing}}{{^editing}}/applications{{/editing}}"><div class="card-body">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <div class="row g-3"><div class="col-md-6"><label class="form-label" for="name"><i class="fa-solid fa-fingerprint" aria-hidden="true"></i> {{#t}}application.form.name{{/t}}</label><input class="form-control" id="name" name="name" value="{{application.name}}" pattern="[A-Za-z0-9][A-Za-z0-9_-]{2,63}" {{#editing}}readonly{{/editing}} required><div class="form-text">{{#t}}application.form.nameHelp{{/t}}</div></div><div class="col-md-6"><label class="form-label" for="displayName"><i class="fa-solid fa-signature" aria-hidden="true"></i> {{#t}}application.form.displayName{{/t}}</label><input class="form-control" id="displayName" name="displayName" value="{{application.displayName}}" required></div><div class="col-12"><label class="form-label" for="healthCheckUrl"><i class="fa-solid fa-link" aria-hidden="true"></i> {{#t}}application.form.url{{/t}}</label><input class="form-control" id="healthCheckUrl" name="healthCheckUrl" type="url" value="{{application.healthCheckUrl}}" required></div><div class="col-md-6"><label class="form-label" for="healthCheckTimeoutMs"><i class="fa-solid fa-stopwatch" aria-hidden="true"></i> {{#t}}application.form.timeout{{/t}}</label><input class="form-control" id="healthCheckTimeoutMs" name="healthCheckTimeoutMs" type="number" min="1000" max="30000" value="{{application.healthCheckTimeoutMs}}" required></div><div class="col-md-6"><label class="form-label" for="slowThresholdMs"><i class="fa-solid fa-gauge-high" aria-hidden="true"></i> {{#t}}application.form.slowThreshold{{/t}}</label><input class="form-control" id="slowThresholdMs" name="slowThresholdMs" type="number" min="100" max="29999" value="{{application.slowThresholdMs}}" required></div><div class="col-12"><label class="form-label" for="responseTextMatch"><i class="fa-solid fa-code" aria-hidden="true"></i> {{#t}}application.form.responseMatch{{/t}}</label><input class="form-control font-monospace" id="responseTextMatch" name="responseTextMatch" value="{{application.responseTextMatch}}" maxlength="300" placeholder="&quot;status&quot;\s*:\s*&quot;ok&quot;"><div class="form-text">{{#t}}application.form.responseMatchHelp{{/t}}</div></div></div>
  <fieldset class="mt-4"><legend class="h6"><i class="fa-solid fa-tags me-1" aria-hidden="true"></i>{{#t}}application.form.tags{{/t}}</legend><label class="form-label" for="tagNames">{{#t}}application.form.tagsLabel{{/t}}</label><input class="form-control" id="tagNames" name="tagNames" value="{{application.tagNames}}" data-tag-whitelist="{{tagWhitelist}}" placeholder="{{#t}}application.form.tagsPlaceholder{{/t}}"><div class="form-text">{{#t}}application.form.tagsHelp{{/t}}</div></fieldset>
</div><div class="card-footer"><button class="btn btn-primary" type="submit">{{#t}}application.form.saveBtn{{/t}}</button> <a class="btn btn-outline-secondary" href="/applications">{{#t}}application.form.cancel{{/t}}</a></div></form>
