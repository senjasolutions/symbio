<!-- Shared application form keeps health defaults and inline tags consistent. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">Applications</a></li><li class="breadcrumb-item active">{{#editing}}Edit{{/editing}}{{^editing}}Add{{/editing}}</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-window-maximize me-1" aria-hidden="true"></i>{{#editing}}Edit Application{{/editing}}{{^editing}}Add Application{{/editing}}</h1>
{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#editing}}/applications/{{application.id}}/edit{{/editing}}{{^editing}}/applications{{/editing}}"><div class="card-body">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <div class="row g-3"><div class="col-md-6"><label class="form-label" for="name"><i class="fa-solid fa-fingerprint" aria-hidden="true"></i> Internal name</label><input class="form-control" id="name" name="name" value="{{application.name}}" pattern="[A-Za-z0-9][A-Za-z0-9_-]{2,63}" {{#editing}}readonly{{/editing}} required><div class="form-text">Permanent 3–64 character slug.</div></div><div class="col-md-6"><label class="form-label" for="displayName"><i class="fa-solid fa-signature" aria-hidden="true"></i> Display name</label><input class="form-control" id="displayName" name="displayName" value="{{application.displayName}}" required></div><div class="col-12"><label class="form-label" for="healthCheckUrl"><i class="fa-solid fa-link" aria-hidden="true"></i> Health-check URL</label><input class="form-control" id="healthCheckUrl" name="healthCheckUrl" type="url" value="{{application.healthCheckUrl}}" required></div><div class="col-md-6"><label class="form-label" for="healthCheckTimeoutMs"><i class="fa-solid fa-stopwatch" aria-hidden="true"></i> Timeout (milliseconds)</label><input class="form-control" id="healthCheckTimeoutMs" name="healthCheckTimeoutMs" type="number" min="1000" max="30000" value="{{application.healthCheckTimeoutMs}}" required></div><div class="col-md-6"><label class="form-label" for="slowThresholdMs"><i class="fa-solid fa-gauge-high" aria-hidden="true"></i> Slow threshold (milliseconds)</label><input class="form-control" id="slowThresholdMs" name="slowThresholdMs" type="number" min="100" max="29999" value="{{application.slowThresholdMs}}" required></div><div class="col-12"><label class="form-label" for="responseTextMatch"><i class="fa-solid fa-code" aria-hidden="true"></i> Required response regular expression (optional)</label><input class="form-control font-monospace" id="responseTextMatch" name="responseTextMatch" value="{{application.responseTextMatch}}" maxlength="300" placeholder="&quot;status&quot;\s*:\s*&quot;ok&quot;"><div class="form-text">JavaScript regex without `/` delimiters. Checked against the first 64 KB of the response.</div></div></div>
  <fieldset class="mt-4"><legend class="h6"><i class="fa-solid fa-tags me-1" aria-hidden="true"></i>Tags</legend><label class="form-label" for="tagNames">Application tags</label><input class="form-control" id="tagNames" name="tagNames" value="{{application.tagNames}}" data-tag-whitelist="{{tagWhitelist}}" placeholder="Production, WordPress"><div class="form-text">Choose existing tags or enter a new one. Without JavaScript, enter comma-separated names; maximum ten tags.</div></fieldset>
</div><div class="card-footer"><button class="btn btn-primary" type="submit">Save application</button> <a class="btn btn-outline-secondary" href="/applications">Cancel</a></div></form>
