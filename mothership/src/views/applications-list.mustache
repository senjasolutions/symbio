<!-- Application list includes active/deleted targets and relational tag filtering. -->
<div class="d-flex justify-content-between align-items-center mb-3"><div><p class="text-secondary small text-uppercase mb-1">Monitoring Targets</p><h1 class="h3 mb-0">Applications</h1></div><a class="btn btn-primary" href="/applications/new">Add Application</a></div>
<div class="mb-3"><span class="me-2 text-secondary">Filter:</span><a class="btn btn-outline-secondary btn-sm" href="/applications">All</a> {{#tags}}<a class="btn btn-outline-secondary btn-sm" href="/applications?tag={{id}}">{{name}}</a> {{/tags}}</div>
<section class="card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Name</th><th>Tags</th><th>Status</th><th>Response</th><th>Last checked</th><th></th></tr></thead><tbody>{{#applications}}<tr class="{{#isDeleted}}table-secondary{{/isDeleted}}"><td><a href="/applications/{{id}}">{{display_name}}</a><div class="small text-secondary"><code>{{name}}</code></div></td><td>{{tagNames}}</td><td><span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span></td><td>{{responseTimeLabel}}</td><td>{{observedAtLabel}}</td><td>{{^isDeleted}}<a class="btn btn-outline-primary btn-sm" href="/applications/{{id}}/edit">Edit</a>{{/isDeleted}}{{#isDeleted}}Deleted{{/isDeleted}}</td></tr>{{/applications}}{{^applications}}<tr><td colspan="6">No applications configured.</td></tr>{{/applications}}</tbody></table></div></section>
