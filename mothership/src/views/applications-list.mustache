<!-- Application list includes active/deleted targets and relational tag filtering. -->
<div class="d-flex justify-content-between align-items-center mb-3"><div><p class="text-secondary small text-uppercase mb-1">{{#t}}applications.monitoringTargets{{/t}}</p><h1 class="h3 mb-0">{{#t}}applications.title{{/t}}</h1></div><div>{{^aiNotConfigured}}<form class="d-inline" method="post" action="/applications/ai-discover"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-outline-primary me-2" type="submit"><i class="fa-solid fa-brain me-1" aria-hidden="true"></i> {{#t}}applications.aiDiscover{{/t}}</button></form>{{/aiNotConfigured}}<a class="btn btn-primary" href="/applications/new">{{#t}}applications.add{{/t}}</a></div></div>
<div class="mb-3"><span class="me-2 text-secondary">{{#t}}applications.filter{{/t}}</span><a class="btn btn-outline-secondary btn-sm" href="/applications">{{#t}}applications.all{{/t}}</a> {{#tags}}<a class="btn btn-outline-secondary btn-sm" href="/applications?tag={{id}}">{{name}}</a> {{/tags}}</div>
<section class="card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>{{#t}}applications.tableName{{/t}}</th><th>{{#t}}applications.tags{{/t}}</th><th>{{#t}}applications.status{{/t}}</th><th>{{#t}}applications.response{{/t}}</th><th>{{#t}}applications.lastChecked{{/t}}</th><th></th></tr></thead><tbody>{{#applications}}<tr class="{{#isDeleted}}table-secondary{{/isDeleted}}"><td><a href="/applications/{{id}}">{{display_name}}</a><div class="small text-secondary"><code>{{name}}</code></div></td><td>{{tagNames}}</td><td><span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span></td><td>{{responseTimeLabel}}</td><td>{{observedAtLabel}}</td><td>{{^isDeleted}}<a class="btn btn-outline-primary btn-sm" href="/applications/{{id}}/edit">{{#t}}application.detail.edit{{/t}}</a>{{/isDeleted}}{{#isDeleted}}{{#t}}common.deleted{{/t}}{{/isDeleted}}</td></tr>{{/applications}}{{^applications}}<tr><td colspan="6">{{#t}}applications.noApplications{{/t}}</td></tr>{{/applications}}</tbody></table></div></section>
