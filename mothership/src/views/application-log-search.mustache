<!-- Search output is escaped in this server-rendered page because log text is untrusted. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">{{#t}}nav.applications{{/t}}</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}">{{application.displayName}}</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}/logs/{{log.id}}">{{log.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}application.log.search.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-magnifying-glass me-1" aria-hidden="true"></i>{{#t}}application.log.search.title{{/t}}</h1>
{{#error}}<div class="alert alert-danger" role="alert">{{error}}</div>{{/error}}
<form class="card mb-3" method="post" action="/applications/{{application.id}}/logs/{{log.id}}/search"><div class="card-body"><input type="hidden" name="_csrf" value="{{csrfToken}}"><label class="form-label" for="query">{{#t}}application.log.search.textToFind{{/t}}</label><div class="input-group"><input class="form-control" id="query" name="query" maxlength="500" value="{{query}}" required><button class="btn btn-primary" type="submit">{{#t}}application.log.search.submit{{/t}}</button></div><div class="form-text">{{#t}}application.log.search.caseHelp{{/t}}</div></div></form>
{{#logContent}}<pre class="log-output">{{logContent}}</pre><p class="text-secondary small">{{bytes}} bytes{{#truncated}} · {{#t}}application.log.search.truncated{{/t}}{{/truncated}}</p>{{/logContent}}{{^logContent}}{{^error}}<p class="text-secondary">{{#t}}application.log.search.noResults{{/t}}</p>{{/error}}{{/logContent}}
<a class="btn btn-outline-secondary btn-sm" href="/applications/{{application.id}}/logs/{{log.id}}">{{#t}}application.log.search.backToViewer{{/t}}</a>
