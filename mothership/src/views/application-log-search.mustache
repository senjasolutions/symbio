<!-- Search output is escaped in this server-rendered page because log text is untrusted. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">Applications</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}">{{application.displayName}}</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}/logs/{{log.id}}">{{log.displayName}}</a></li><li class="breadcrumb-item active">Search</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-magnifying-glass me-1" aria-hidden="true"></i>Literal Log Search</h1>
{{#error}}<div class="alert alert-danger" role="alert">{{error}}</div>{{/error}}
<form class="card mb-3" method="post" action="/applications/{{application.id}}/logs/{{log.id}}/search"><div class="card-body"><input type="hidden" name="_csrf" value="{{csrfToken}}"><label class="form-label" for="query">Text to find</label><div class="input-group"><input class="form-control" id="query" name="query" maxlength="500" value="{{query}}" required><button class="btn btn-primary" type="submit">Search</button></div><div class="form-text">Case-sensitive literal text; newest 8 MB only.</div></div></form>
{{#logContent}}<pre class="log-output">{{logContent}}</pre><p class="text-secondary small">{{bytes}} bytes{{#truncated}} · Output or scan window truncated{{/truncated}}</p>{{/logContent}}{{^logContent}}{{^error}}<p class="text-secondary">No matches found.</p>{{/error}}{{/logContent}}
<a class="btn btn-outline-secondary btn-sm" href="/applications/{{application.id}}/logs/{{log.id}}">Back to viewer</a>
