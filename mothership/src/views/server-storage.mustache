<!-- Storage details list filesystems with usage bars and disk I/O activity counters from /proc. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">Servers</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">Storage</li></ol></nav>
<h1 class="h3 mb-1">Storage &amp; Disk I/O</h1>
<p class="text-secondary small mb-3">All detected mounted filesystems with usage bars, plus cumulative read/write counters per disk device from /proc/diskstats.</p>
<section class="card mb-4"><div class="card-header"><strong><i class="fa-solid fa-hard-drive me-1" aria-hidden="true"></i>Filesystems</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Mount point</th><th class="d-none d-md-table-cell">Type</th><th>Used</th><th class="d-none d-md-table-cell">Available</th><th>Usage</th></tr></thead><tbody>{{#storage}}<tr><td class="fw-bold">{{mountPoint}}</td><td class="d-none d-md-table-cell">{{fsType}}</td><td>{{usedLabel}}</td><td class="d-none d-md-table-cell">{{availableLabel}}</td><td><div class="d-flex align-items-center gap-2"><div class="flex-grow-1" style="height:6px;border-radius:2px;overflow:hidden;background:#dce3e9;font-size:0;line-height:0"><span style="display:inline-block;width:{{usePercent}}%;height:6px;background:#216fa8;vertical-align:top;border-radius:2px 0 0 2px"></span></div><small>{{usePercent}}%</small></div></td></tr>{{/storage}}{{^storage}}<tr><td colspan="5" class="text-muted">No usable filesystem inventory received yet.</td></tr>{{/storage}}</tbody></table></div></section>
{{#ioError}}<div class="alert alert-warning" role="alert">Disk I/O unavailable: {{ioError}}</div>{{/ioError}}
<section class="card"><div class="card-header"><strong><i class="fa-solid fa-gauge-high me-1" aria-hidden="true"></i>Disk I/O (cumulative since boot)</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Device</th><th>Reads</th><th class="d-none d-md-table-cell">Sectors Read</th><th>Writes</th><th class="d-none d-md-table-cell">Sectors Written</th><th class="d-none d-lg-table-cell">I/O Time</th></tr></thead><tbody>{{#diskIO}}<tr><td class="fw-bold font-monospace">{{name}}</td><td>{{readsLabel}}</td><td class="d-none d-md-table-cell">{{sectorsRead}}</td><td>{{writesLabel}}</td><td class="d-none d-md-table-cell">{{sectorsWritten}}</td><td class="d-none d-lg-table-cell">{{ioTimeLabel}}</td></tr>{{/diskIO}}{{^diskIO}}<tr><td colspan="6" class="text-muted">No disk I/O data available.</td></tr>{{/diskIO}}</tbody></table></div></section>
