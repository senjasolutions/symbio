<!-- Storage details list filesystems with usage bars and disk I/O activity counters from /proc. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.storage.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.storage.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.storage.description{{/t}}</p>
<section class="card mb-4"><div class="card-header"><strong><i class="fa-solid fa-hard-drive me-1" aria-hidden="true"></i>{{#t}}server.storage.filesystems{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}server.storage.mountPoint{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.storage.type{{/t}}</th><th>{{#t}}server.storage.used{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.storage.available{{/t}}</th><th>{{#t}}server.storage.usePercent{{/t}}</th></tr></thead><tbody>{{#storage}}<tr><td class="fw-bold">{{mountPoint}}</td><td class="d-none d-md-table-cell">{{fsType}}</td><td>{{usedLabel}}</td><td class="d-none d-md-table-cell">{{availableLabel}}</td><td><div class="d-flex align-items-center gap-2"><div class="flex-grow-1" style="height:6px;border-radius:2px;overflow:hidden;background:#dce3e9;font-size:0;line-height:0"><span style="display:inline-block;width:{{usePercent}}%;height:6px;background:#216fa8;vertical-align:top;border-radius:2px 0 0 2px"></span></div><small>{{usePercent}}%</small></div></td></tr>{{/storage}}{{^storage}}<tr><td colspan="5" class="text-muted">{{#t}}server.detail.noStorage{{/t}}</td></tr>{{/storage}}</tbody></table></div></section>
{{#ioError}}<div class="alert alert-warning" role="alert">{{#t}}server.storage.ioAlert{{/t}}</div>{{/ioError}}
<section class="card"><div class="card-header"><strong><i class="fa-solid fa-gauge-high me-1" aria-hidden="true"></i>{{#t}}server.storage.diskIOCumulative{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}server.storage.device{{/t}}</th><th>{{#t}}server.storage.reads{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.storage.sectorsRead{{/t}}</th><th>{{#t}}server.storage.writes{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.storage.sectorsWritten{{/t}}</th><th class="d-none d-lg-table-cell">{{#t}}server.storage.ioTime{{/t}}</th></tr></thead><tbody>{{#diskIO}}<tr><td class="fw-bold font-monospace">{{name}}</td><td>{{readsLabel}}</td><td class="d-none d-md-table-cell">{{sectorsRead}}</td><td>{{writesLabel}}</td><td class="d-none d-md-table-cell">{{sectorsWritten}}</td><td class="d-none d-lg-table-cell">{{ioTimeLabel}}</td></tr>{{/diskIO}}{{^diskIO}}<tr><td colspan="6" class="text-muted">{{#t}}server.storage.noDiskIO{{/t}}</td></tr>{{/diskIO}}</tbody></table></div></section>
