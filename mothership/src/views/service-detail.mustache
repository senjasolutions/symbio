<!-- Service detail shows immutable recent evidence instead of overstating health. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item active">{{service.displayName}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1">{{service.displayName}}</h1><p class="text-secondary mb-0">Evidence: {{latest.evidence}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">24 hours</a><a class="btn btn-outline-primary" href="?range=7d">7 days</a></div>
<section class="card"><div class="card-header"><strong>Recent checks</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Observed</th><th>Status</th><th>Evidence</th><th>Response</th><th>Description</th></tr></thead><tbody>{{#recent}}<tr><td>{{observedAtLabel}}</td><td><span class="badge text-bg-{{statusClass}}">{{status}}</span></td><td>{{evidence}}</td><td>{{responseTimeLabel}}</td><td>{{description}}</td></tr>{{/recent}}{{^recent}}<tr><td colspan="5">No checks received.</td></tr>{{/recent}}</tbody></table></div></section>
