<!-- Service detail shows immutable recent evidence instead of overstating health. -->
<nav aria-label="{{#t}}nav.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item active">{{service.displayName}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1">{{service.displayName}}</h1><p class="text-secondary mb-0">{{#t}}service.detail.evidence{{/t}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">{{#t}}service.detail.range24h{{/t}}</a><a class="btn btn-outline-primary" href="?range=7d">{{#t}}service.detail.range7d{{/t}}</a></div>
<section class="card"><div class="card-header"><strong>{{#t}}service.detail.recentChecks{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}service.detail.observed{{/t}}</th><th>{{#t}}service.detail.status{{/t}}</th><th>{{#t}}service.detail.evidenceHeader{{/t}}</th><th>{{#t}}service.detail.response{{/t}}</th><th>{{#t}}service.detail.description{{/t}}</th></tr></thead><tbody>{{#recent}}<tr><td>{{observedAtLabel}}</td><td><span class="badge text-bg-{{statusClass}}">{{status}}</span></td><td>{{evidence}}</td><td>{{responseTimeLabel}}</td><td>{{description}}</td></tr>{{/recent}}{{^recent}}<tr><td colspan="5">{{#t}}service.detail.noChecks{{/t}}</td></tr>{{/recent}}</tbody></table></div></section>
