<!-- Network interfaces show every detected adapter with state, MAC, speed, addresses, and counters. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.networking.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.networking.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.networking.description{{/t}}</p>
<section class="card"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}server.networking.interface{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.networking.status{{/t}}</th><th class="d-none d-lg-table-cell">{{#t}}server.networking.mac{{/t}}</th><th class="d-none d-lg-table-cell">MTU</th><th>{{#t}}server.networking.addresses{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.networking.counters{{/t}}</th></tr></thead><tbody>{{#networking}}<tr><td class="fw-bold">{{name}}{{#speedMbps}} <small class="text-muted">{{speedMbps}} {{#t}}server.networking.mbps{{/t}}</small>{{/speedMbps}}</td><td class="d-none d-md-table-cell"><span class="badge text-bg-{{#stateIsUp}}success{{/stateIsUp}}{{^stateIsUp}}secondary{{/stateIsUp}}">{{state}}</span></td><td class="d-none d-lg-table-cell font-monospace small">{{mac}}</td><td class="d-none d-lg-table-cell">{{mtu}}</td><td class="small">{{addressList}}{{^addressList}}—{{/addressList}}</td><td class="d-none d-md-table-cell small">{{countersLabel}}</td></tr>{{/networking}}{{^networking}}<tr><td colspan="6" class="text-muted">{{#t}}server.networking.noData{{/t}}</td></tr>{{/networking}}</tbody></table></div></section>
