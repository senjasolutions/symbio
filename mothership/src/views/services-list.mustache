<!-- Known-service table keeps truthful status context while reserving evidence detail for each service page. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">Servers</a></li><li class="breadcrumb-item"><a href="/servers/{{serverId}}">Server</a></li><li class="breadcrumb-item active">Services</li></ol></nav>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3 mb-0">Services</h1></div><a class="btn btn-outline-secondary" href="/servers/{{serverId}}/services">Refresh</a></div>
<div class="alert alert-info">Service status always includes its evidence type. “Detected” is not equivalent to a successful protocol health check.</div>
<section class="card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Service</th><th>Enabled</th><th>Current probe status</th><th>Last checked</th><th></th></tr></thead><tbody>{{#services}}<tr class="{{#disabled}}service-disabled{{/disabled}}"><td><i class="{{serviceIcon}} me-1" aria-hidden="true"></i><a href="/servers/{{serverId}}/services/{{id}}">{{display_name}}</a></td><td><strong>{{enabledLabel}}</strong></td><td><span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span></td><td>{{observedAtLabel}}</td><td><a class="btn btn-outline-primary btn-sm" href="/servers/{{serverId}}/services/{{id}}/edit">Configure</a></td></tr>{{/services}}</tbody></table></div></section>
