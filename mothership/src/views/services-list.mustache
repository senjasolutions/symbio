<!-- Known-service table keeps truthful status context while reserving evidence detail for each service page. -->
<nav aria-label="{{#t}}nav.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}server.breadcrumb.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{serverId}}">{{#t}}server.breadcrumb.server{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}services.title{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3 mb-0">{{#t}}services.title{{/t}}</h1></div><a class="btn btn-outline-secondary" href="/servers/{{serverId}}/services">{{#t}}services.refresh{{/t}}</a></div>
<div class="alert alert-info">{{#t}}services.evidenceNote{{/t}}</div>
<section class="card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>{{#t}}services.name{{/t}}</th><th>{{#t}}services.enabled{{/t}}</th><th>{{#t}}services.status{{/t}}</th><th>{{#t}}services.lastChecked{{/t}}</th><th class="text-end">{{#t}}services.actions{{/t}}</th></tr></thead><tbody>{{#services}}<tr class="{{#disabled}}service-disabled{{/disabled}}"><td><i class="{{serviceIcon}} me-1" aria-hidden="true"></i><a href="/servers/{{serverId}}/services/{{id}}">{{display_name}}</a></td><td><strong>{{enabledLabel}}</strong></td><td><span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span></td><td>{{observedAtLabel}}</td><td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/servers/{{serverId}}/services/{{id}}/edit">{{#t}}services.configure{{/t}}</a>{{#supportsRestart}} <form method="post" action="/servers/{{serverId}}/services/{{id}}/restart" class="d-inline" data-confirm="{{#t}}services.confirmRestart{{/t}} {{display_name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-outline-warning btn-sm" type="submit" title="{{#t}}services.restart{{/t}}"><i class="fa-solid fa-rotate" aria-hidden="true"></i></button></form>{{/supportsRestart}}</td></tr>{{/services}}</tbody></table></div></section>
