<!-- Agent recent data shows the last 50 monitoring samples with per-core CPU, memory, and disk values. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.recentData.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.recentData.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.recentData.description{{/t}}</p>
<section class="card"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}server.recentData.observed{{/t}}</th><th>{{#t}}server.recentData.cpuAverage{{/t}}</th><th>{{#t}}server.recentData.allCores{{/t}}</th><th>{{#t}}server.recentData.memory{{/t}}</th><th>{{#t}}server.recentData.disk{{/t}}</th></tr></thead><tbody>{{#recent}}<tr><td>{{observedAtLabel}}</td><td>{{cpuDisplay}}</td><td class="small">{{cpuCores}}</td><td>{{memoryDisplay}}</td><td>{{diskDisplay}}</td></tr>{{/recent}}{{^recent}}<tr><td colspan="5">{{#t}}server.recentData.noSamples{{/t}}</td></tr>{{/recent}}</tbody></table></div></section>
