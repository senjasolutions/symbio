<!-- Agent recent data shows the last 50 monitoring samples with per-core CPU, memory, and disk values. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">Servers</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">Agent Recent Data</li></ol></nav>
<h1 class="h3 mb-1">Agent Recent Data</h1>
<p class="text-secondary small mb-3">The most recent 50 monitoring samples collected by the agent. Each row represents one complete collection cycle.</p>
<section class="card"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Observed</th><th>CPU average</th><th>All cores</th><th>Memory</th><th>Disk</th></tr></thead><tbody>{{#recent}}<tr><td>{{observedAtLabel}}</td><td>{{cpuDisplay}}</td><td class="small">{{cpuCores}}</td><td>{{memoryDisplay}}</td><td>{{diskDisplay}}</td></tr>{{/recent}}{{^recent}}<tr><td colspan="5">No samples received.</td></tr>{{/recent}}</tbody></table></div></section>
