<!-- Shared tag form supports dedicated create and rename operations. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/application-tags">Application Tags</a></li><li class="breadcrumb-item active">{{#tag}}Edit{{/tag}}{{^tag}}Add{{/tag}}</li></ol></nav>
<h1 class="h3 mb-3">{{#tag}}Edit Tag{{/tag}}{{^tag}}Add Tag{{/tag}}</h1>{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#tag}}/application-tags/{{tag.id}}/edit{{/tag}}{{^tag}}/application-tags{{/tag}}"><div class="card-body"><input type="hidden" name="_csrf" value="{{csrfToken}}"><label class="form-label" for="name">Tag name</label><input class="form-control" id="name" name="name" maxlength="50" value="{{tag.name}}" required></div><div class="card-footer"><button class="btn btn-primary" type="submit">Save tag</button> <a class="btn btn-outline-secondary" href="/application-tags">Cancel</a></div></form>
