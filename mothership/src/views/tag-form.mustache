<!-- Shared tag form supports dedicated create and rename operations. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/application-tags">{{#t}}tags.title{{/t}}</a></li><li class="breadcrumb-item active">{{#tag}}{{#t}}common.edit{{/t}}{{/tag}}{{^tag}}{{#t}}common.add{{/t}}{{/tag}}</li></ol></nav>
<h1 class="h3 mb-3">{{#tag}}{{#t}}tags.form.editTitle{{/t}}{{/tag}}{{^tag}}{{#t}}tags.form.addTitle{{/t}}{{/tag}}</h1>{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#tag}}/application-tags/{{tag.id}}/edit{{/tag}}{{^tag}}/application-tags{{/tag}}"><div class="card-body"><input type="hidden" name="_csrf" value="{{csrfToken}}"><label class="form-label" for="name">{{#t}}tags.form.name{{/t}}</label><input class="form-control" id="name" name="name" maxlength="50" value="{{tag.name}}" required></div><div class="card-footer"><button class="btn btn-primary" type="submit">{{#t}}tags.form.save{{/t}}</button> <a class="btn btn-outline-secondary" href="/application-tags">{{#t}}tags.form.cancel{{/t}}</a></div></form>
