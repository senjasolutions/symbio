<!-- Application log registration stores a source definition; the agent reads content later. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">Applications</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}">{{application.displayName}}</a></li><li class="breadcrumb-item active">{{#editing}}Edit Log{{/editing}}{{^editing}}Add Log{{/editing}}</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-file-lines me-1" aria-hidden="true"></i>{{#editing}}Edit Log Source{{/editing}}{{^editing}}Add Log Source{{/editing}}</h1>
{{#error}}<div class="alert alert-danger" role="alert">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#editing}}/applications/{{application.id}}/logs/{{log.id}}/edit{{/editing}}{{^editing}}/applications/{{application.id}}/logs{{/editing}}"><div class="card-body"><input type="hidden" name="_csrf" value="{{csrfToken}}"><div class="row g-3"><div class="col-md-6"><label class="form-label" for="displayName">Log name</label><input class="form-control" id="displayName" name="displayName" maxlength="120" value="{{log.displayName}}" placeholder="Application error log" required></div><div class="col-md-6"><label class="form-label" for="tailLines">Default tail size</label><select class="form-select" id="tailLines" name="tailLines">{{#tailChoices}}<option value="{{value}}" {{#selected}}selected{{/selected}}>{{value}} lines</option>{{/tailChoices}}</select></div><div class="col-12"><label class="form-label" for="filePath">Absolute host log path</label><input class="form-control font-monospace" id="filePath" name="filePath" value="{{log.filePath}}" placeholder="/var/log/my-application/error.log" required><div class="form-text">Only this registered path can be read. Directories, traversal, symlinks, Docker logs, and PM2 logs are rejected.</div></div></div></div><div class="card-footer"><button class="btn btn-primary" type="submit">Save log source</button> <a class="btn btn-outline-secondary" href="/applications/{{application.id}}">Cancel</a></div></form>
