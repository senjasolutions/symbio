<!-- Application log registration stores a source definition; the agent reads content later. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">{{#t}}nav.applications{{/t}}</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}">{{application.displayName}}</a></li><li class="breadcrumb-item active">{{#editing}}{{#t}}application.log.form.editTitle{{/t}}{{/editing}}{{^editing}}{{#t}}application.log.form.addTitle{{/t}}{{/editing}}</li></ol></nav>
<h1 class="h3 mb-3"><i class="fa-solid fa-file-lines me-1" aria-hidden="true"></i>{{#editing}}{{#t}}application.log.form.editTitle{{/t}}{{/editing}}{{^editing}}{{#t}}application.log.form.addTitle{{/t}}{{/editing}}</h1>
{{#error}}<div class="alert alert-danger" role="alert">{{error}}</div>{{/error}}
<form class="card" method="post" action="{{#editing}}/applications/{{application.id}}/logs/{{log.id}}/edit{{/editing}}{{^editing}}/applications/{{application.id}}/logs{{/editing}}"><div class="card-body"><input type="hidden" name="_csrf" value="{{csrfToken}}"><div class="row g-3"><div class="col-md-6"><label class="form-label" for="displayName">{{#t}}application.log.form.logName{{/t}}</label><input class="form-control" id="displayName" name="displayName" maxlength="120" value="{{log.displayName}}" placeholder="{{#t}}application.log.form.logNamePlaceholder{{/t}}" required></div><div class="col-md-6"><label class="form-label" for="tailLines">{{#t}}application.log.form.tailSize{{/t}}</label><select class="form-select" id="tailLines" name="tailLines">{{#tailChoices}}<option value="{{value}}" {{#selected}}selected{{/selected}}>{{#t}}application.log.form.linesOption{{/t}}</option>{{/tailChoices}}</select></div><div class="col-12"><label class="form-label" for="filePath">{{#t}}application.log.form.pathLabel{{/t}}</label><input class="form-control font-monospace" id="filePath" name="filePath" value="{{log.filePath}}" placeholder="{{#t}}application.log.form.pathPlaceholder{{/t}}" required><div class="form-text">{{#t}}application.log.form.pathHelp{{/t}}</div></div></div></div><div class="card-footer"><button class="btn btn-primary" type="submit">{{#t}}application.log.form.saveBtn{{/t}}</button> <a class="btn btn-outline-secondary" href="/applications/{{application.id}}">{{#t}}application.log.form.cancel{{/t}}</a></div></form>
