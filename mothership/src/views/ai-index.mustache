<!-- Symbio Intelligence root page — links to AI features. -->
<h1 class="h3 mb-3"><i class="fa-solid fa-brain me-1" aria-hidden="true"></i>{{#t}}ai.symbioIntelligence{{/t}}</h1>
<p class="text-secondary mb-4">{{#t}}ai.symbioIntelligenceDesc{{/t}}</p>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-body text-center py-4">
        <i class="fa-solid fa-clock-rotate-left fa-2x text-secondary mb-2" aria-hidden="true"></i>
        <h5 class="card-title">{{#t}}ai.history{{/t}}</h5>
        <p class="card-text text-secondary small">{{#t}}ai.historyDesc{{/t}}</p>
        <a class="btn btn-outline-primary" href="/ai/history">{{#t}}ai.viewHistory{{/t}}</a>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-body text-center py-4">
        <i class="fa-solid fa-chart-simple fa-2x text-secondary mb-2" aria-hidden="true"></i>
        <h5 class="card-title">{{#t}}settings.llmUsage{{/t}}</h5>
        <p class="card-text text-secondary small">{{#t}}ai.usageDesc{{/t}}</p>
        <a class="btn btn-outline-primary" href="/settings?tab=llm">{{#t}}settings.llm{{/t}}</a>
      </div>
    </div>
  </div>
</div>