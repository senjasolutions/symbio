<!-- Server list deliberately exposes one real server and a disabled future action. -->
<div class="d-flex justify-content-between align-items-center mb-3"><div><p class="text-secondary small text-uppercase mb-1">{{#t}}servers.infrastructure{{/t}}</p><h1 class="h3 mb-0">{{#t}}servers.title{{/t}}</h1></div><button class="btn btn-secondary" disabled>{{#t}}servers.addServer{{/t}}</button></div>
<section class="card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>{{#t}}servers.name{{/t}}</th><th>{{#t}}servers.hostname{{/t}}</th><th>{{#t}}servers.ip{{/t}}</th><th>{{#t}}servers.quickStats{{/t}}</th><th>{{#t}}servers.status{{/t}}</th><th>{{#t}}servers.lastReport{{/t}}</th></tr></thead><tbody>{{#servers}}<tr><td><a href="/servers/{{id}}">{{displayName}}</a></td><td>{{hostname}}</td><td>{{primaryIp}}</td><td><i class="fa-solid fa-microchip"></i> {{cpuDisplay}} · <i class="fa-solid fa-memory"></i> {{memoryDisplay}} · <i class="fa-solid fa-hard-drive"></i> {{diskDisplay}}</td><td><span class="badge text-bg-{{stateClass}} status-badge">{{state}}</span></td><td>{{lastSeenAt}}</td></tr>{{/servers}}</tbody></table></div></section>
