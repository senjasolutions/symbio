<!-- Apache service detail shows installed modules and enabled virtual hosts. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}apache.breadcrumb{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{#t}}apache.title{{/t}}</h1><p class="text-secondary mb-0">{{#t}}apache.description{{/t}}</p><p class="small text-secondary mb-0">{{#t}}service.detail.evidence{{/t}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">{{#t}}common.range24h{{/t}}</a><a class="btn btn-outline-primary" href="?range=7d">{{#t}}common.range7d{{/t}}</a></div>
{{#apacheError}}<div class="alert alert-warning">{{apacheError}}</div>{{/apacheError}}
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-globe me-1" aria-hidden="true"></i> {{#t}}apache.virtualHosts{{/t}}</strong></div>{{#apacheSites.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}apache.sites.config{{/t}}</th><th>{{#t}}apache.sites.address{{/t}}</th><th>{{#t}}apache.sites.serverName{{/t}}</th><th>{{#t}}apache.sites.documentRoot{{/t}}</th><th>{{#t}}apache.sites.ssl{{/t}}</th><th>{{#t}}apache.sites.aliases{{/t}}</th></tr></thead><tbody>{{#apacheSites}}<tr><td><code>{{file}}</code></td><td>{{addresses}}</td><td><strong>{{serverName}}</strong></td><td class="small"><code>{{documentRoot}}</code></td><td>{{#ssl}}<span class="badge text-bg-success">{{#t}}common.yes{{/t}}</span>{{/ssl}}{{^ssl}}<span class="badge text-bg-secondary">{{#t}}common.no{{/t}}</span>{{/ssl}}</td><td class="small">{{aliases}}</td></tr>{{/apacheSites}}</tbody></table></div>{{/apacheSites.length}}{{^apacheSites.length}}<div class="card-body text-secondary">{{#t}}apache.sites.none{{/t}}</div>{{/apacheSites.length}}</section>
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-puzzle-piece me-1" aria-hidden="true"></i> {{#t}}apache.modules{{/t}}</strong></div>{{#apacheModules.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}apache.modules.header{{/t}}</th></tr></thead><tbody>{{#apacheModules}}<tr><td><code>{{.}}</code></td></tr>{{/apacheModules}}</tbody></table></div>{{/apacheModules.length}}{{^apacheModules.length}}<div class="card-body text-secondary">{{#t}}apache.modules.none{{/t}}</div>{{/apacheModules.length}}</section>
