<!-- Apache service detail shows installed modules and enabled virtual hosts. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item active">Apache</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> Apache</h1><p class="text-secondary mb-0">Apache HTTP server — the most widely used web server software.</p><p class="small text-secondary mb-0">Evidence: {{latest.evidence}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">24 hours</a><a class="btn btn-outline-primary" href="?range=7d">7 days</a></div>
{{#apacheError}}<div class="alert alert-warning">{{apacheError}}</div>{{/apacheError}}
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-puzzle-piece me-1" aria-hidden="true"></i> Modules</strong></div>{{#apacheModules.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Module</th></tr></thead><tbody>{{#apacheModules}}<tr><td><code>{{.}}</code></td></tr>{{/apacheModules}}</tbody></table></div>{{/apacheModules.length}}{{^apacheModules.length}}<div class="card-body text-secondary">No modules detected.</div>{{/apacheModules.length}}</section>
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-globe me-1" aria-hidden="true"></i> Virtual Hosts</strong></div>{{#apacheSites.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Config</th><th>Address</th><th>Server Name</th><th>Document Root</th><th>SSL</th><th>Aliases</th></tr></thead><tbody>{{#apacheSites}}<tr><td><code>{{file}}</code></td><td>{{addresses}}</td><td><strong>{{serverName}}</strong></td><td class="small"><code>{{documentRoot}}</code></td><td>{{#ssl}}<span class="badge text-bg-success">Yes</span>{{/ssl}}{{^ssl}}<span class="badge text-bg-secondary">No</span>{{/ssl}}</td><td class="small">{{aliases}}</td></tr>{{/apacheSites}}</tbody></table></div>{{/apacheSites.length}}{{^apacheSites.length}}<div class="card-body text-secondary">No virtual hosts configured.</div>{{/apacheSites.length}}</section>
