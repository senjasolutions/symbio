<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services/{{service.id}}">{{#t}}docker.breadcrumb{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services/{{service.id}}">{{#t}}docker.containers{{/t}}</a></li><li class="breadcrumb-item active">{{container.name}}</li></ol></nav>
{{#error}}
<div class="alert alert-danger">{{error}}</div>
<a class="btn btn-outline-primary" href="/servers/{{service.serverId}}/services/{{service.id}}">{{#t}}docker.back{{/t}}</a>
{{/error}}
{{^error}}
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{container.name}}</h1></div><div><span class="badge text-bg-{{#container.state.running}}success{{/container.state.running}}{{^container.state.running}}secondary{{/container.state.running}} status-badge">{{container.state.status}}</span></div></div>
<!-- Container action buttons -->
<div class="mb-3">
  <div class="btn-group btn-group-sm">
    {{#container.state.running}}
    <form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/container/{{container.id}}/action" class="d-inline" data-confirm="{{#t}}docker.confirmStop{{/t}} {{container.name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="stop"><input type="hidden" name="container" value="{{container.name}}"><button class="btn btn-outline-warning" type="submit"><i class="fa-solid fa-stop" aria-hidden="true"></i> {{#t}}docker.stop{{/t}}</button></form>
    <form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/container/{{container.id}}/action" class="d-inline" data-confirm="{{#t}}docker.confirmRestart{{/t}} {{container.name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="restart"><input type="hidden" name="container" value="{{container.name}}"><button class="btn btn-outline-info" type="submit"><i class="fa-solid fa-rotate" aria-hidden="true"></i> {{#t}}docker.restart{{/t}}</button></form>
    {{/container.state.running}}
    {{^container.state.running}}
    <form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/container/{{container.id}}/action" class="d-inline"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="start"><input type="hidden" name="container" value="{{container.name}}"><button class="btn btn-outline-success" type="submit"><i class="fa-solid fa-play" aria-hidden="true"></i> {{#t}}docker.start{{/t}}</button></form>
    <form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/container/{{container.id}}/action" class="d-inline" data-confirm="{{#t}}docker.confirmRemove{{/t}} {{container.name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="remove"><input type="hidden" name="container" value="{{container.name}}"><button class="btn btn-outline-danger" type="submit"><i class="fa-solid fa-trash" aria-hidden="true"></i> {{#t}}docker.remove{{/t}}</button></form>
    {{/container.state.running}}
  </div>
</div>
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-circle-info me-1" aria-hidden="true"></i> {{#t}}common.general{{/t}}</strong></div><table class="table table-sm mb-0"><tbody><tr><th style="width:120px">{{#t}}docker.container.id{{/t}}</th><td><code>{{container.id}}</code></td></tr><tr><th>{{#t}}docker.container.image{{/t}}</th><td>{{container.image}}</td></tr><tr><th>{{#t}}docker.container.platform{{/t}}</th><td>{{container.platform}}</td></tr><tr><th>{{#t}}docker.container.created{{/t}}</th><td>{{container.created}}</td></tr><tr><th>{{#t}}docker.container.started{{/t}}</th><td>{{container.state.startedAt}}</td></tr><tr><th>{{#t}}docker.container.restartCount{{/t}}</th><td>{{container.state.restartCount}}</td></tr></tbody></table></section>
{{#container.ports}}
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-plug me-1" aria-hidden="true"></i> {{#t}}docker.container.ports{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}docker.container.containerPort{{/t}}</th><th>{{#t}}docker.container.protocol{{/t}}</th><th>{{#t}}docker.container.hostIp{{/t}}</th><th>{{#t}}docker.container.hostPort{{/t}}</th></tr></thead><tbody>{{#container.ports}}<tr><td>{{containerPort}}</td><td>{{protocol}}</td><td>{{#bindings}}{{hostIp}}{{/bindings}}{{^bindings}}—{{/bindings}}</td><td>{{#bindings}}{{hostPort}}{{/bindings}}{{^bindings}}—{{/bindings}}</td></tr>{{/container.ports}}</tbody></table></div></section>
{{/container.ports}}
{{#container.network}}
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-network-wired me-1" aria-hidden="true"></i> {{#t}}docker.container.network{{/t}}</strong></div><table class="table table-sm mb-0"><tbody><tr><th style="width:120px">{{#t}}docker.container.networkName{{/t}}</th><td>{{container.network.name}}</td></tr><tr><th>{{#t}}docker.container.ipAddress{{/t}}</th><td>{{container.network.ip}}</td></tr><tr><th>{{#t}}docker.container.gateway{{/t}}</th><td>{{container.network.gateway}}</td></tr></tbody></table></section>
{{/container.network}}
<a class="btn btn-outline-primary" href="/servers/{{service.serverId}}/services/{{service.id}}">{{#t}}docker.back{{/t}}</a>
{{/error}}
