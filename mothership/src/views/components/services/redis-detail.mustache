<!-- Redis service detail shows live INFO sections from the Redis server. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item active">Redis</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> Redis</h1><p class="text-secondary mb-0">Redis key-value store — in-memory data structure server.</p><p class="small text-secondary mb-0">Evidence: {{latest.evidence}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div></div>
{{#infoError}}<div class="alert alert-warning">{{infoError}}</div>{{/infoError}}
{{#info}}
{{#server.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-server me-1" aria-hidden="true"></i> Server</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#server}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/server}}</tbody></table></div></section>{{/server.length}}
{{#memory.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-memory me-1" aria-hidden="true"></i> Memory</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#memory}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/memory}}</tbody></table></div></section>{{/memory.length}}
{{#clients.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-users me-1" aria-hidden="true"></i> Clients</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#clients}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/clients}}</tbody></table></div></section>{{/clients.length}}
{{#stats.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-chart-bar me-1" aria-hidden="true"></i> Stats</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#stats}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/stats}}</tbody></table></div></section>{{/stats.length}}
{{#keyspace.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-key me-1" aria-hidden="true"></i> Keyspace</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#keyspace}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/keyspace}}</tbody></table></div></section>{{/keyspace.length}}
{{/info}}
{{^info}}
<section class="card mb-3"><div class="card-body text-secondary">Redis INFO data unavailable.</div></section>
{{/info}}
