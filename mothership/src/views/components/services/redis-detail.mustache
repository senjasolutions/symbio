<!-- Redis service detail shows live INFO sections from the Redis server. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}redis.breadcrumb{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{#t}}redis.title{{/t}}</h1><p class="text-secondary mb-0">{{#t}}redis.description{{/t}}</p><p class="small text-secondary mb-0">{{#t}}service.detail.evidence{{/t}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div></div>
{{#infoError}}<div class="alert alert-warning">{{infoError}}</div>{{/infoError}}
{{#info}}
{{#server.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-server me-1" aria-hidden="true"></i> {{#t}}redis.server{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#server}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/server}}</tbody></table></div></section>{{/server.length}}
{{#memory.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-memory me-1" aria-hidden="true"></i> {{#t}}redis.memory{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#memory}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/memory}}</tbody></table></div></section>{{/memory.length}}
{{#clients.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-users me-1" aria-hidden="true"></i> {{#t}}redis.clients{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#clients}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/clients}}</tbody></table></div></section>{{/clients.length}}
{{#stats.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-chart-bar me-1" aria-hidden="true"></i> {{#t}}redis.stats{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#stats}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/stats}}</tbody></table></div></section>{{/stats.length}}
{{#keyspace.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-key me-1" aria-hidden="true"></i> {{#t}}redis.keyspace{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>{{#keyspace}}<tr><th>{{key}}</th><td>{{value}}</td></tr>{{/keyspace}}</tbody></table></div></section>{{/keyspace.length}}
{{/info}}
{{^info}}
<section class="card mb-3"><div class="card-body text-secondary">{{#t}}redis.infoUnavailable{{/t}}</div></section>
{{/info}}
