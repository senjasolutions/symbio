<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}docker.breadcrumb{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{#t}}docker.title{{/t}}</h1><p class="text-secondary mb-0">{{#t}}docker.description{{/t}}</p><p class="small text-secondary mb-0">{{#t}}service.detail.evidence{{/t}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">{{#t}}common.range24h{{/t}}</a><a class="btn btn-outline-primary" href="?range=7d">{{#t}}common.range7d{{/t}}</a></div>
{{#fetchError}}<div class="alert alert-danger"><strong>{{#t}}docker.inventoryUnavailable{{/t}}</strong> {{fetchError}}</div>{{/fetchError}}
{{^fetchError}}
<ul class="nav nav-tabs mb-3">
  <li class="nav-item"><a class="nav-link{{#tabContainers}} active{{/tabContainers}}" href="?tab=containers"><i class="fa-solid fa-box me-1" aria-hidden="true"></i> {{#t}}docker.containers{{/t}}{{#containers.length}} <span class="badge text-bg-secondary">{{containers.length}}</span>{{/containers.length}}</a></li>
  <li class="nav-item"><a class="nav-link{{#tabVolumes}} active{{/tabVolumes}}" href="?tab=volumes"><i class="fa-solid fa-database me-1" aria-hidden="true"></i> {{#t}}docker.volumes{{/t}}{{#volumes.length}} <span class="badge text-bg-secondary">{{volumes.length}}</span>{{/volumes.length}}</a></li>
  <li class="nav-item"><a class="nav-link{{#tabNetworks}} active{{/tabNetworks}}" href="?tab=networks"><i class="fa-solid fa-network-wired me-1" aria-hidden="true"></i> {{#t}}docker.networks{{/t}}{{#networks.length}} <span class="badge text-bg-secondary">{{networks.length}}</span>{{/networks.length}}</a></li>
</ul>
{{#tabContainers}}
{{#containersError}}<div class="alert alert-warning">{{containersError}}</div>{{/containersError}}
<section class="card mb-3"><div class="card-header d-flex justify-content-between align-items-center"><strong>{{#t}}docker.containers{{/t}}</strong><div class="btn-group btn-group-sm"><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/prune" class="d-inline" data-confirm="{{#t}}docker.confirmPruneSystem{{/t}}"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="type" value="system"><button class="btn btn-outline-warning btn-sm" type="submit"><i class="fa-solid fa-broom" aria-hidden="true"></i> {{#t}}docker.pruneSystem{{/t}}</button></form><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/prune" class="d-inline" data-confirm="{{#t}}docker.confirmPruneImages{{/t}}"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="type" value="images"><button class="btn btn-outline-warning btn-sm" type="submit">{{#t}}docker.pruneImages{{/t}}</button></form></div></div>{{#containers.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}docker.containers.name{{/t}}</th><th>{{#t}}docker.containers.image{{/t}}</th><th>{{#t}}docker.containers.state{{/t}}</th><th>{{#t}}docker.containers.status{{/t}}</th><th>{{#t}}docker.containers.created{{/t}}</th><th class="text-end">{{#t}}docker.containers.actions{{/t}}</th></tr></thead><tbody>{{#containers}}<tr><td><strong>{{name}}</strong></td><td>{{image}}</td><td><span class="badge text-bg-{{#running}}success{{/running}}{{^running}}secondary{{/running}}">{{state}}</span></td><td>{{status}}</td><td class="small">{{created}}</td><td class="text-end"><div class="btn-group btn-group-sm"><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/docker/containers/{{id}}">{{#t}}docker.containers.detail{{/t}}</a>{{#running}}<form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/container/{{id}}/action" class="d-inline" data-confirm="{{#t}}docker.confirmStop{{/t}} {{name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="stop"><input type="hidden" name="container" value="{{name}}"><button class="btn btn-outline-warning btn-sm" type="submit" title="{{#t}}docker.stop{{/t}}"><i class="fa-solid fa-stop" aria-hidden="true"></i></button></form><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/container/{{id}}/action" class="d-inline" data-confirm="{{#t}}docker.confirmRestart{{/t}} {{name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="restart"><input type="hidden" name="container" value="{{name}}"><button class="btn btn-outline-info btn-sm" type="submit" title="{{#t}}docker.restart{{/t}}"><i class="fa-solid fa-rotate" aria-hidden="true"></i></button></form>{{/running}}{{^running}}<form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/container/{{id}}/action" class="d-inline"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="start"><input type="hidden" name="container" value="{{name}}"><button class="btn btn-outline-success btn-sm" type="submit" title="{{#t}}docker.start{{/t}}"><i class="fa-solid fa-play" aria-hidden="true"></i></button></form><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/container/{{id}}/action" class="d-inline" data-confirm="{{#t}}docker.confirmRemove{{/t}} {{name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="remove"><input type="hidden" name="container" value="{{name}}"><button class="btn btn-outline-danger btn-sm" type="submit" title="{{#t}}docker.remove{{/t}}"><i class="fa-solid fa-trash" aria-hidden="true"></i></button></form>{{/running}}</div></td></tr>{{/containers}}</tbody></table></div>{{/containers.length}}{{^containers.length}}{{^containersError}}<div class="card-body text-secondary">{{#t}}docker.containers.none{{/t}}</div>{{/containersError}}{{/containers.length}}</section>
{{/tabContainers}}
{{#tabVolumes}}
{{#volumesError}}<div class="alert alert-warning">{{volumesError}}</div>{{/volumesError}}
<section class="card mb-3"><div class="card-header d-flex justify-content-between align-items-center"><strong>{{#t}}docker.volumes{{/t}}</strong><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/prune" class="d-inline" data-confirm="{{#t}}docker.confirmPruneVolumes{{/t}}"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="type" value="volumes"><button class="btn btn-outline-warning btn-sm" type="submit"><i class="fa-solid fa-broom" aria-hidden="true"></i> {{#t}}docker.pruneVolumes{{/t}}</button></form></div>{{#volumes.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}docker.volumes.name{{/t}}</th><th>{{#t}}docker.volumes.driver{{/t}}</th><th>{{#t}}docker.volumes.mountpoint{{/t}}</th><th class="text-end">{{#t}}docker.volumes.actions{{/t}}</th></tr></thead><tbody>{{#volumes}}<tr><td><strong>{{name}}</strong></td><td>{{driver}}</td><td class="small"><code>{{mountpoint}}</code></td><td class="text-end"><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/docker/volume/{{name}}/remove" class="d-inline" data-confirm="{{#t}}docker.confirmRemoveVolume{{/t}} {{name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-outline-danger btn-sm" type="submit"><i class="fa-solid fa-trash" aria-hidden="true"></i></button></form></td></tr>{{/volumes}}</tbody></table></div>{{/volumes.length}}{{^volumes.length}}{{^volumesError}}<div class="card-body text-secondary">{{#t}}docker.volumes.none{{/t}}</div>{{/volumesError}}{{/volumes.length}}</section>
{{/tabVolumes}}
{{#tabNetworks}}
{{#networksError}}<div class="alert alert-warning">{{networksError}}</div>{{/networksError}}
<section class="card mb-3"><div class="card-header"><strong>{{#t}}docker.networks{{/t}}</strong></div>{{#networks.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}docker.networks.name{{/t}}</th><th>{{#t}}docker.networks.driver{{/t}}</th><th>{{#t}}docker.networks.scope{{/t}}</th><th>{{#t}}docker.networks.subnet{{/t}}</th></tr></thead><tbody>{{#networks}}<tr><td><strong>{{name}}</strong></td><td>{{driver}}</td><td>{{scope}}</td><td class="small"><code>{{subnet}}</code></td></tr>{{/networks}}</tbody></table></div>{{/networks.length}}{{^networks.length}}{{^networksError}}<div class="card-body text-secondary">{{#t}}docker.networks.none{{/t}}</div>{{/networksError}}{{/networks.length}}</section>
{{/tabNetworks}}
{{/fetchError}}
<section class="card mt-3"><div class="card-header"><strong><i class="fa-solid fa-clock-rotate-left me-1" aria-hidden="true"></i> {{#t}}service.detail.recentChecks{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}service.detail.observed{{/t}}</th><th>{{#t}}dashboard.status{{/t}}</th><th>{{#t}}service.detail.evidenceHeader{{/t}}</th><th>{{#t}}service.detail.responseTime{{/t}}</th><th>{{#t}}service.detail.description{{/t}}</th></tr></thead><tbody>{{#recent}}<tr><td>{{observedAtLabel}}</td><td><span class="badge text-bg-{{statusClass}}">{{status}}</span></td><td>{{evidence}}</td><td>{{responseTimeLabel}}</td><td>{{description}}</td></tr>{{/recent}}{{^recent}}<tr><td colspan="5">{{#t}}service.detail.noChecks{{/t}}</td></tr>{{/recent}}</tbody></table></div></section>
