<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item active">Docker</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> Docker</h1><p class="text-secondary mb-0">Docker container runtime — monitors whether the Docker daemon is available on the host.</p><p class="small text-secondary mb-0">Evidence: {{latest.evidence}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">24 hours</a><a class="btn btn-outline-primary" href="?range=7d">7 days</a></div>
{{#fetchError}}<div class="alert alert-danger"><strong>Docker inventory unavailable:</strong> {{fetchError}}</div>{{/fetchError}}
{{^fetchError}}
<ul class="nav nav-tabs mb-3">
  <li class="nav-item"><a class="nav-link{{#tabContainers}} active{{/tabContainers}}" href="?tab=containers"><i class="fa-solid fa-box me-1" aria-hidden="true"></i> Containers{{#containers.length}} <span class="badge text-bg-secondary">{{containers.length}}</span>{{/containers.length}}</a></li>
  <li class="nav-item"><a class="nav-link{{#tabVolumes}} active{{/tabVolumes}}" href="?tab=volumes"><i class="fa-solid fa-database me-1" aria-hidden="true"></i> Volumes{{#volumes.length}} <span class="badge text-bg-secondary">{{volumes.length}}</span>{{/volumes.length}}</a></li>
  <li class="nav-item"><a class="nav-link{{#tabNetworks}} active{{/tabNetworks}}" href="?tab=networks"><i class="fa-solid fa-network-wired me-1" aria-hidden="true"></i> Networks{{#networks.length}} <span class="badge text-bg-secondary">{{networks.length}}</span>{{/networks.length}}</a></li>
</ul>
{{#tabContainers}}
{{#containersError}}<div class="alert alert-warning">{{containersError}}</div>{{/containersError}}
<section class="card mb-3"><div class="card-header"><strong>Containers</strong></div>{{#containers.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Image</th><th>State</th><th>Status</th><th>Created</th><th></th></tr></thead><tbody>{{#containers}}<tr><td><strong>{{name}}</strong></td><td>{{image}}</td><td><span class="badge text-bg-{{#running}}success{{/running}}{{^running}}secondary{{/running}}">{{state}}</span></td><td>{{status}}</td><td class="small">{{created}}</td><td><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/docker/containers/{{id}}">Detail</a></td></tr>{{/containers}}</tbody></table></div>{{/containers.length}}{{^containers.length}}{{^containersError}}<div class="card-body text-secondary">No containers found.</div>{{/containersError}}{{/containers.length}}</section>
{{/tabContainers}}
{{#tabVolumes}}
{{#volumesError}}<div class="alert alert-warning">{{volumesError}}</div>{{/volumesError}}
<section class="card mb-3"><div class="card-header"><strong>Volumes</strong></div>{{#volumes.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Driver</th><th>Mountpoint</th></tr></thead><tbody>{{#volumes}}<tr><td><strong>{{name}}</strong></td><td>{{driver}}</td><td class="small"><code>{{mountpoint}}</code></td></tr>{{/volumes}}</tbody></table></div>{{/volumes.length}}{{^volumes.length}}{{^volumesError}}<div class="card-body text-secondary">No volumes found.</div>{{/volumesError}}{{/volumes.length}}</section>
{{/tabVolumes}}
{{#tabNetworks}}
{{#networksError}}<div class="alert alert-warning">{{networksError}}</div>{{/networksError}}
<section class="card mb-3"><div class="card-header"><strong>Networks</strong></div>{{#networks.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Driver</th><th>Scope</th><th>Subnet</th></tr></thead><tbody>{{#networks}}<tr><td><strong>{{name}}</strong></td><td>{{driver}}</td><td>{{scope}}</td><td class="small"><code>{{subnet}}</code></td></tr>{{/networks}}</tbody></table></div>{{/networks.length}}{{^networks.length}}{{^networksError}}<div class="card-body text-secondary">No networks found.</div>{{/networksError}}{{/networks.length}}</section>
{{/tabNetworks}}
{{/fetchError}}
<section class="card mt-3"><div class="card-header"><strong><i class="fa-solid fa-clock-rotate-left me-1" aria-hidden="true"></i> Recent checks</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Observed</th><th>Status</th><th>Evidence</th><th>Response</th><th>Description</th></tr></thead><tbody>{{#recent}}<tr><td>{{observedAtLabel}}</td><td><span class="badge text-bg-{{statusClass}}">{{status}}</span></td><td>{{evidence}}</td><td>{{responseTimeLabel}}</td><td>{{description}}</td></tr>{{/recent}}{{^recent}}<tr><td colspan="5">No checks received.</td></tr>{{/recent}}</tbody></table></div></section>
