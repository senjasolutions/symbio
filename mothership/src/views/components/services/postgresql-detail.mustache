<!-- PostgreSQL service detail shows server status, key settings, and database list with drill-down navigation. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item active">PostgreSQL</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> PostgreSQL</h1><p class="text-secondary mb-0">PostgreSQL database server — read-only status, schema browsing, and table data viewer.</p><p class="small text-secondary mb-0">Evidence: {{latest.evidence}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">24 hours</a><a class="btn btn-outline-primary" href="?range=7d">7 days</a></div>
{{#pgError}}<div class="alert alert-danger">{{pgError}}</div>{{/pgError}}
{{#needsCredentials}}<div class="alert alert-warning"><strong>PostgreSQL credentials required.</strong> {{credentialHint}} <a class="btn btn-sm btn-outline-primary ms-2" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div>{{/needsCredentials}}
{{^needsCredentials}}
{{#server}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-server me-1" aria-hidden="true"></i> Server</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody><tr><th>Version</th><td>{{version}}</td></tr>{{#uptime}}<tr><th>Started At</th><td>{{start_time}}</td></tr>{{/uptime}}</tbody></table></div></section>{{/server}}
{{#settings.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-cog me-1" aria-hidden="true"></i> Settings</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Setting</th><th>Value</th><th>Unit</th></tr></thead><tbody>{{#settings}}<tr><td>{{name}}</td><td>{{setting}}</td><td>{{unit}}</td></tr>{{/settings}}</tbody></table></div></section>{{/settings.length}}
{{#stats}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-chart-bar me-1" aria-hidden="true"></i> Database Stats</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody><tr><th>Active Connections</th><td>{{active_connections}}</td></tr><tr><th>Total Transactions</th><td>{{total_transactions}}</td></tr><tr><th>Commits</th><td>{{xact_commit}}</td></tr><tr><th>Rollbacks</th><td>{{xact_rollback}}</td></tr><tr><th>Blocks Read</th><td>{{blks_read}}</td></tr><tr><th>Blocks Hit</th><td>{{blks_hit}}</td></tr><tr><th>Tuples Returned</th><td>{{tup_returned}}</td></tr><tr><th>Tuples Inserted</th><td>{{tup_inserted}}</td></tr><tr><th>Tuples Updated</th><td>{{tup_updated}}</td></tr><tr><th>Tuples Deleted</th><td>{{tup_deleted}}</td></tr></tbody></table></div></section>{{/stats}}
{{#databases}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-layer-group me-1" aria-hidden="true"></i> Databases</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Database</th><th></th></tr></thead><tbody>{{#databases}}<tr><td><strong>{{name}}</strong></td><td><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/postgresql/databases/{{name}}/tables">Browse</a></td></tr>{{/databases}}{{^databases}}<tr><td colspan="2" class="text-secondary">No databases found.</td></tr>{{/databases}}</tbody></table></div></section>{{/databases}}
{{/needsCredentials}}
