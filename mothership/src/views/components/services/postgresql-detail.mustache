<!-- PostgreSQL service detail shows server status, key settings, and database list with drill-down navigation. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}postgresql.breadcrumb{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{#t}}postgresql.title{{/t}}</h1><p class="text-secondary mb-0">{{#t}}postgresql.description{{/t}}</p><p class="small text-secondary mb-0">{{#t}}service.detail.evidence{{/t}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">{{#t}}common.range24h{{/t}}</a><a class="btn btn-outline-primary" href="?range=7d">{{#t}}common.range7d{{/t}}</a></div>
{{#pgError}}<div class="alert alert-danger">{{pgError}}</div>{{/pgError}}
{{#needsCredentials}}<div class="alert alert-warning"><strong>{{#t}}postgresql.credentialsRequired{{/t}}</strong> {{credentialHint}} <a class="btn btn-sm btn-outline-primary ms-2" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div>{{/needsCredentials}}
{{^needsCredentials}}
{{#server}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-server me-1" aria-hidden="true"></i> {{#t}}postgresql.server{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody><tr><th>{{#t}}postgresql.version{{/t}}</th><td>{{version}}</td></tr>{{#uptime}}<tr><th>{{#t}}postgresql.startedAt{{/t}}</th><td>{{start_time}}</td></tr>{{/uptime}}</tbody></table></div></section>{{/server}}
{{#settings.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-cog me-1" aria-hidden="true"></i> {{#t}}postgresql.settings{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}postgresql.settings.setting{{/t}}</th><th>{{#t}}postgresql.settings.value{{/t}}</th><th>{{#t}}postgresql.settings.unit{{/t}}</th></tr></thead><tbody>{{#settings}}<tr><td>{{name}}</td><td>{{setting}}</td><td>{{unit}}</td></tr>{{/settings}}</tbody></table></div></section>{{/settings.length}}
{{#stats}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-chart-bar me-1" aria-hidden="true"></i> {{#t}}postgresql.databaseStats{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody><tr><th>{{#t}}postgresql.activeConnections{{/t}}</th><td>{{active_connections}}</td></tr><tr><th>{{#t}}postgresql.totalTransactions{{/t}}</th><td>{{total_transactions}}</td></tr><tr><th>{{#t}}postgresql.commits{{/t}}</th><td>{{xact_commit}}</td></tr><tr><th>{{#t}}postgresql.rollbacks{{/t}}</th><td>{{xact_rollback}}</td></tr><tr><th>{{#t}}postgresql.blocksRead{{/t}}</th><td>{{blks_read}}</td></tr><tr><th>{{#t}}postgresql.blocksHit{{/t}}</th><td>{{blks_hit}}</td></tr><tr><th>{{#t}}postgresql.tuplesReturned{{/t}}</th><td>{{tup_returned}}</td></tr><tr><th>{{#t}}postgresql.tuplesInserted{{/t}}</th><td>{{tup_inserted}}</td></tr><tr><th>{{#t}}postgresql.tuplesUpdated{{/t}}</th><td>{{tup_updated}}</td></tr><tr><th>{{#t}}postgresql.tuplesDeleted{{/t}}</th><td>{{tup_deleted}}</td></tr></tbody></table></div></section>{{/stats}}
{{#databases}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-layer-group me-1" aria-hidden="true"></i> {{#t}}postgresql.databases{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}postgresql.databases.header{{/t}}</th><th></th></tr></thead><tbody>{{#databases}}<tr><td><strong>{{name}}</strong></td><td><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/postgresql/databases/{{name}}/tables">{{#t}}postgresql.databases.browse{{/t}}</a></td></tr>{{/databases}}{{^databases}}<tr><td colspan="2" class="text-secondary">{{#t}}postgresql.databases.none{{/t}}</td></tr>{{/databases}}</tbody></table></div></section>{{/databases}}
{{/needsCredentials}}
