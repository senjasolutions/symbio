<!-- PM2 service detail shows live process list managed by PM2 daemon. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item active">PM2</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> PM2</h1><p class="text-secondary mb-0">PM2 process manager — manages Node.js application processes on the host.</p><p class="small text-secondary mb-0">Evidence: {{latest.evidence}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div></div>
{{#processesError}}<div class="alert alert-warning"><strong>Process inventory unavailable:</strong> {{processesError}}</div>{{/processesError}}
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-list me-1" aria-hidden="true"></i> Managed Processes</strong></div>{{#processes.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Name</th><th>PID</th><th>Status</th><th>Mode</th><th>Uptime</th><th>Memory</th><th>CPU</th><th>Restarts</th></tr></thead><tbody>{{#processes}}<tr><td><strong>{{name}}</strong>{{#version}} <span class="badge text-bg-secondary">{{version}}</span>{{/version}}</td><td>{{pid}}</td><td><span class="badge text-bg-{{#online}}success{{/online}}{{^online}}{{#stopped}}secondary{{/stopped}}{{^stopped}}warning{{/stopped}}{{/online}}">{{status}}</span></td><td>{{mode}}</td><td class="small">{{uptime}}</td><td class="small">{{memory}}</td><td class="small">{{cpu}}</td><td>{{restarts}}</td></tr>{{/processes}}</tbody></table></div>{{/processes.length}}{{^processes.length}}{{^processesError}}<div class="card-body text-secondary">No processes registered with PM2.</div>{{/processesError}}{{/processes.length}}</section>
