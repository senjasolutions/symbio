<!-- PM2 service detail shows live process list managed by PM2 daemon. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}pm2.breadcrumb{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{#t}}pm2.title{{/t}}</h1><p class="text-secondary mb-0">{{#t}}pm2.description{{/t}}</p><p class="small text-secondary mb-0">{{#t}}service.detail.evidence{{/t}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div></div>
{{#processesError}}<div class="alert alert-warning"><strong>{{#t}}pm2.processesError{{/t}}</strong> {{processesError}}</div>{{/processesError}}
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-list me-1" aria-hidden="true"></i> {{#t}}pm2.processes{{/t}}</strong></div>{{#processes.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}pm2.processes.name{{/t}}</th><th>{{#t}}pm2.processes.pid{{/t}}</th><th>{{#t}}pm2.processes.status{{/t}}</th><th>{{#t}}pm2.processes.mode{{/t}}</th><th>{{#t}}pm2.processes.uptime{{/t}}</th><th>{{#t}}pm2.processes.memory{{/t}}</th><th>{{#t}}pm2.processes.cpu{{/t}}</th><th>{{#t}}pm2.processes.restarts{{/t}}</th><th class="text-end">{{#t}}pm2.processes.actions{{/t}}</th></tr></thead><tbody>{{#processes}}<tr><td><strong>{{name}}</strong>{{#version}} <span class="badge text-bg-secondary">{{version}}</span>{{/version}}</td><td>{{pid}}</td><td><span class="badge text-bg-{{#online}}success{{/online}}{{^online}}{{#stopped}}secondary{{/stopped}}{{^stopped}}warning{{/stopped}}{{/online}}">{{status}}</span></td><td>{{mode}}</td><td class="small">{{uptime}}</td><td class="small">{{memory}}</td><td class="small">{{cpu}}</td><td>{{restarts}}</td><td class="text-end"><div class="btn-group btn-group-sm">{{#online}}<form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/pm2/process/action" class="d-inline" data-confirm="{{#t}}pm2.confirmStop{{/t}} {{name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="stop"><input type="hidden" name="name" value="{{name}}"><button class="btn btn-outline-warning btn-sm" type="submit" title="{{#t}}pm2.stop{{/t}}"><i class="fa-solid fa-stop" aria-hidden="true"></i></button></form><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/pm2/process/action" class="d-inline" data-confirm="{{#t}}pm2.confirmRestart{{/t}} {{name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="restart"><input type="hidden" name="name" value="{{name}}"><button class="btn btn-outline-info btn-sm" type="submit" title="{{#t}}pm2.restart{{/t}}"><i class="fa-solid fa-rotate" aria-hidden="true"></i></button></form>{{/online}}{{#stopped}}<form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/pm2/process/action" class="d-inline"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="start"><input type="hidden" name="name" value="{{name}}"><button class="btn btn-outline-success btn-sm" type="submit" title="{{#t}}pm2.start{{/t}}"><i class="fa-solid fa-play" aria-hidden="true"></i></button></form>{{/stopped}}<form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/pm2/process/action" class="d-inline" data-confirm="{{#t}}pm2.confirmDelete{{/t}} {{name}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="action" value="delete"><input type="hidden" name="name" value="{{name}}"><button class="btn btn-outline-danger btn-sm" type="submit" title="{{#t}}pm2.delete{{/t}}"><i class="fa-solid fa-trash" aria-hidden="true"></i></button></form></div></td></tr>{{/processes}}</tbody></table></div>{{/processes.length}}{{^processes.length}}{{^processesError}}<div class="card-body text-secondary">{{#t}}pm2.processes.none{{/t}}</div>{{/processesError}}{{/processes.length}}</section>
