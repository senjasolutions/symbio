<!-- MySQL table browse page shows table data in a paginated read-only view. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services/{{service.id}}">MySQL / MariaDB</a></li><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services/{{service.id}}/mysql/databases/{{dbName}}/tables">{{dbName}}</a></li><li class="breadcrumb-item active">{{tableName}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3 mb-1"><code>{{tableName}}</code></h1><p class="text-secondary mb-0">Showing up to 100 rows</p></div></div>
{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
{{#columns.length}}<section class="card"><div class="card-header"><strong><i class="fa-solid fa-table me-1" aria-hidden="true"></i> {{tableName}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0 table-striped"><thead><tr>{{#columns}}<th>{{.}}</th>{{/columns}}</tr></thead><tbody>{{#rows}}<tr>{{#.}}<td><code>{{.}}</code></td>{{/.}}</tr>{{/rows}}</tbody></table></div></section>{{/columns.length}}
{{^columns.length}}{{^error}}<section class="card"><div class="card-body text-secondary">No data returned or table is empty.</div></section>{{/error}}{{/columns.length}}
