<!-- PostgreSQL table browse page shows table data with search and pagination. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services/{{service.id}}">{{#t}}postgresql.breadcrumb{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services/{{service.id}}/postgresql/databases/{{dbName}}/tables">{{dbName}}</a></li><li class="breadcrumb-item active">{{schemaName}}.{{tableName}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3 mb-1"><code>{{schemaName}}.{{tableName}}</code></h1>{{#total}}<p class="text-secondary mb-0">{{total}} {{#t}}postgresql.browse.rowsTotal{{/t}}{{#search}} · {{#t}}postgresql.browse.searchLabel{{/t}}: "{{search}}"{{/search}}</p>{{/total}}{{^total}}<p class="text-secondary mb-0">{{#t}}postgresql.browse.noRows{{/t}}</p>{{/total}}</div></div>
{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
<form class="row g-2 mb-3" method="get" action=""><div class="col-auto"><input class="form-control form-control-sm" type="text" name="search" value="{{search}}" placeholder="{{#t}}postgresql.browse.searchPlaceholder{{/t}}"></div><div class="col-auto"><button class="btn btn-sm btn-outline-primary" type="submit"><i class="fa-solid fa-search" aria-hidden="true"></i> {{#t}}postgresql.browse.search{{/t}}</button></div>{{#search}}<div class="col-auto"><a class="btn btn-sm btn-outline-secondary" href="?page=1">{{#t}}postgresql.browse.clear{{/t}}</a></div>{{/search}}</form>
{{#columns.length}}
<section class="card"><div class="card-header d-flex justify-content-between align-items-center"><strong><i class="fa-solid fa-table me-1" aria-hidden="true"></i> {{tableName}}</strong>{{#totalPages}}<small class="text-secondary">{{#t}}postgresql.browse.pageOf{{/t}}</small>{{/totalPages}}</div><div class="table-responsive"><table class="table table-sm mb-0 table-striped"><thead><tr>{{#columns}}<th>{{.}}</th>{{/columns}}</tr></thead><tbody>{{#rows}}<tr>{{#.}}<td><code>{{.}}</code></td>{{/.}}</tr>{{/rows}}{{^rows}}<tr><td colspan="{{columns.length}}" class="text-secondary">{{#t}}postgresql.browse.noMatches{{/t}}</td></tr>{{/rows}}</tbody></table></div>{{#totalPages}}
<div class="card-footer d-flex justify-content-between align-items-center"><small class="text-secondary">{{#t}}postgresql.browse.rowsPerPage{{/t}}</small><nav aria-label="{{#t}}common.tablePagination{{/t}}"><ul class="pagination pagination-sm mb-0">{{#hasPrev}}<li class="page-item"><a class="page-link" href="?page={{prevPage}}{{#search}}&search={{search}}{{/search}}>{{#t}}common.previous{{/t}}</a></li>{{/hasPrev}}{{^hasPrev}}<li class="page-item disabled"><span class="page-link>{{#t}}common.previous{{/t}}</span></li>{{/hasPrev}}<li class="page-item disabled"><span class="page-link">{{page}} / {{totalPages}}</span></li>{{#hasNext}}<li class="page-item"><a class="page-link" href="?page={{nextPage}}{{#search}}&search={{search}}{{/search}}>{{#t}}common.next{{/t}}</a></li>{{/hasNext}}{{^hasNext}}<li class="page-item disabled"><span class="page-link>{{#t}}common.next{{/t}}</span></li>{{/hasNext}}</ul></nav></div>{{/totalPages}}</section>
{{/columns.length}}
{{^columns.length}}{{^error}}<section class="card"><div class="card-body text-secondary">{{#t}}postgresql.browse.noData{{/t}}</div></section>{{/error}}{{/columns.length}}
