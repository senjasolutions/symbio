<!-- Nginx service detail shows installed modules and enabled sites. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item active">Nginx</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> Nginx</h1><p class="text-secondary mb-0">Nginx web server — high-performance HTTP server and reverse proxy.</p><p class="small text-secondary mb-0">Evidence: {{latest.evidence}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">24 hours</a><a class="btn btn-outline-primary" href="?range=7d">7 days</a></div>
{{#nginxError}}<div class="alert alert-warning">{{nginxError}}</div>{{/nginxError}}
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-puzzle-piece me-1" aria-hidden="true"></i> Modules</strong></div>{{#nginxModules.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Module</th></tr></thead><tbody>{{#nginxModules}}<tr><td><code>{{.}}</code></td></tr>{{/nginxModules}}</tbody></table></div>{{/nginxModules.length}}{{^nginxModules.length}}<div class="card-body text-secondary">No modules detected.</div>{{/nginxModules.length}}</section>
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-globe me-1" aria-hidden="true"></i> Enabled Sites</strong></div>{{#nginxSites.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Config</th><th>Server Name</th><th>Listen</th><th>SSL</th><th>Root</th><th>Proxy Pass</th></tr></thead><tbody>{{#nginxSites}}<tr><td><code>{{file}}</code></td><td><strong>{{serverNames}}</strong></td><td>{{listen}}</td><td>{{#ssl}}<span class="badge text-bg-success">Yes</span>{{/ssl}}{{^ssl}}<span class="badge text-bg-secondary">No</span>{{/ssl}}</td><td class="small"><code>{{root}}</code></td><td class="small"><code>{{proxyPass}}</code></td></tr>{{/nginxSites}}</tbody></table></div>{{/nginxSites.length}}{{^nginxSites.length}}<div class="card-body text-secondary">No sites configured.</div>{{/nginxSites.length}}</section>
