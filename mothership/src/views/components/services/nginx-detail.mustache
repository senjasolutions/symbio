<!-- Nginx service detail shows installed modules and enabled sites. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}nginx.breadcrumb{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{#t}}nginx.title{{/t}}</h1><p class="text-secondary mb-0">{{#t}}nginx.description{{/t}}</p><p class="small text-secondary mb-0">{{#t}}service.detail.evidence{{/t}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">{{#t}}common.range24h{{/t}}</a><a class="btn btn-outline-primary" href="?range=7d">{{#t}}common.range7d{{/t}}</a></div>
{{#nginxError}}<div class="alert alert-warning">{{nginxError}}</div>{{/nginxError}}
<section class="card mb-3"><div class="card-header d-flex justify-content-between align-items-center"><strong><i class="fa-solid fa-globe me-1" aria-hidden="true"></i> {{#t}}nginx.enabledSites{{/t}}</strong><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/restart" class="d-inline" data-confirm="{{#t}}services.confirmRestart{{/t}} Nginx?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-outline-warning btn-sm" type="submit"><i class="fa-solid fa-rotate" aria-hidden="true"></i> {{#t}}services.restart{{/t}}</button></form></div>{{#nginxSites.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}nginx.sites.config{{/t}}</th><th>{{#t}}nginx.sites.serverName{{/t}}</th><th>{{#t}}nginx.sites.listen{{/t}}</th><th>{{#t}}nginx.sites.ssl{{/t}}</th><th>{{#t}}nginx.sites.root{{/t}}</th><th>{{#t}}nginx.sites.proxyPass{{/t}}</th><th class="text-end">{{#t}}nginx.sites.actions{{/t}}</th></tr></thead><tbody>{{#nginxSites}}<tr><td><code>{{file}}</code></td><td><strong>{{serverNames}}</strong></td><td>{{listen}}</td><td>{{#ssl}}<span class="badge text-bg-success">{{#t}}common.yes{{/t}}</span>{{/ssl}}{{^ssl}}<span class="badge text-bg-secondary">{{#t}}common.no{{/t}}</span>{{/ssl}}</td><td class="small"><code>{{root}}</code></td><td class="small"><code>{{proxyPass}}</code></td><td class="text-end"><div class="btn-group btn-group-sm"><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/file-manager/edit?path=/etc/nginx/sites-enabled/{{file}}" title="{{#t}}nginx.editConfig{{/t}}"><i class="fa-solid fa-pen-to-square" aria-hidden="true"></i></a><form method="post" action="/servers/{{service.serverId}}/services/{{service.id}}/nginx/disable-site" class="d-inline" data-confirm="{{#t}}nginx.confirmDisableSite{{/t}} {{file}}?"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="site" value="{{file}}"><button class="btn btn-outline-warning btn-sm" type="submit" title="{{#t}}nginx.disableSite{{/t}}"><i class="fa-solid fa-toggle-off" aria-hidden="true"></i></button></form></div></td></tr>{{/nginxSites}}</tbody></table></div>{{/nginxSites.length}}{{^nginxSites.length}}<div class="card-body text-secondary">{{#t}}nginx.sites.none{{/t}}</div>{{/nginxSites.length}}</section>
<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-puzzle-piece me-1" aria-hidden="true"></i> {{#t}}nginx.modules{{/t}}</strong></div>{{#nginxModules.length}}<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}nginx.modules.header{{/t}}</th></tr></thead><tbody>{{#nginxModules}}<tr><td><code>{{.}}</code></td></tr>{{/nginxModules}}</tbody></table></div>{{/nginxModules.length}}{{^nginxModules.length}}<div class="card-body text-secondary">{{#t}}nginx.modules.none{{/t}}</div>{{/nginxModules.length}}</section>
