<!-- MySQL database tables page shows all tables in a database. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services/{{service.id}}">{{#t}}mysql.breadcrumb{{/t}}</a></li><li class="breadcrumb-item active">{{dbName}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{dbName}}</h1></div></div>
{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
{{#tables.length}}<section class="card"><div class="card-header"><strong>{{#t}}mysql.tables{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}mysql.tables.table{{/t}}</th><th>{{#t}}mysql.tables.engine{{/t}}</th><th>{{#t}}mysql.tables.rows{{/t}}</th><th>{{#t}}mysql.tables.dataSize{{/t}}</th><th>{{#t}}mysql.tables.indexSize{{/t}}</th><th>{{#t}}mysql.tables.collation{{/t}}</th><th>{{#t}}mysql.tables.created{{/t}}</th><th></th></tr></thead><tbody>{{#tables}}<tr><td><strong>{{name}}</strong></td><td>{{engine}}</td><td>{{rows}}</td><td class="small">{{dataLength}}</td><td class="small">{{indexLength}}</td><td class="small">{{collation}}</td><td class="small">{{createTime}}</td><td><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/mysql/databases/{{dbName}}/tables/{{name}}/browse">{{#t}}mysql.databases.browse{{/t}}</a></td></tr>{{/tables}}</tbody></table></div></section>{{/tables.length}}
{{^tables.length}}{{^error}}<section class="card"><div class="card-body text-secondary">{{#t}}mysql.tables.none{{/t}}</div></section>{{/error}}{{/tables.length}}
