<!-- MySQL / MariaDB service detail shows server status, key variables, and database list with drill-down navigation. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">Services</a></li><li class="breadcrumb-item active">MySQL / MariaDB</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> MySQL / MariaDB</h1><p class="text-secondary mb-0">MySQL or MariaDB database server — read-only status, schema browsing, and table data viewer.</p><p class="small text-secondary mb-0">Evidence: {{latest.evidence}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">24 hours</a><a class="btn btn-outline-primary" href="?range=7d">7 days</a></div>
{{#mysqlError}}<div class="alert alert-danger">{{mysqlError}}</div>{{/mysqlError}}
{{#needsCredentials}}<div class="alert alert-warning"><strong>MySQL credentials required.</strong> {{credentialHint}} <a class="btn btn-sm btn-outline-primary ms-2" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">Configure</a></div>{{/needsCredentials}}
{{^needsCredentials}}
{{#server}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-server me-1" aria-hidden="true"></i> Server</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody><tr><th>Version</th><td>{{version}}</td></tr><tr><th>Version Comment</th><td>{{versionComment}}</td></tr><tr><th>Port</th><td>{{port}}</td></tr><tr><th>Data Directory</th><td><code>{{datadir}}</code></td></tr><tr><th>Server Time</th><td>{{now}}</td></tr></tbody></table></div></section>{{/server}}
{{#statusPairs.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-chart-bar me-1" aria-hidden="true"></i> Global Status</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Variable</th><th>Value</th></tr></thead><tbody>{{#statusPairs}}<tr><td>{{key}}</td><td>{{value}}</td></tr>{{/statusPairs}}</tbody></table></div></section>{{/statusPairs.length}}
{{#variablePairs.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-cog me-1" aria-hidden="true"></i> Key Variables</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Variable</th><th>Value</th></tr></thead><tbody>{{#variablePairs}}<tr><td>{{key}}</td><td>{{value}}</td></tr>{{/variablePairs}}</tbody></table></div></section>{{/variablePairs.length}}
{{#databases}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-layer-group me-1" aria-hidden="true"></i> Databases</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Database</th><th></th></tr></thead><tbody>{{#databases}}<tr><td><strong>{{name}}</strong></td><td><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/mysql/databases/{{name}}/tables">Browse</a></td></tr>{{/databases}}{{^databases}}<tr><td colspan="2" class="text-secondary">No databases found.</td></tr>{{/databases}}</tbody></table></div></section>{{/databases}}
{{/needsCredentials}}
