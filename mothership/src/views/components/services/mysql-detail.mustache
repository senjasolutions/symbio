<!-- MySQL / MariaDB service detail shows server status, key variables, and database list with drill-down navigation. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}mysql.breadcrumb{{/t}}</li></ol></nav>
<div class="d-flex justify-content-between mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{#t}}mysql.title{{/t}}</h1><p class="text-secondary mb-0">{{#t}}mysql.description{{/t}}</p><p class="small text-secondary mb-0">{{#t}}service.detail.evidence{{/t}}</p></div><div><span class="badge text-bg-{{latest.statusClass}} status-badge">{{latest.status}}</span> <a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div></div>
<div class="btn-group mb-3"><a class="btn btn-outline-primary" href="?range=24h">{{#t}}common.range24h{{/t}}</a><a class="btn btn-outline-primary" href="?range=7d">{{#t}}common.range7d{{/t}}</a></div>
{{#mysqlError}}<div class="alert alert-danger">{{mysqlError}}</div>{{/mysqlError}}
{{#needsCredentials}}<div class="alert alert-warning"><strong>{{#t}}mysql.credentialsRequired{{/t}}</strong> {{credentialHint}} <a class="btn btn-sm btn-outline-primary ms-2" href="/servers/{{service.serverId}}/services/{{service.id}}/edit">{{#t}}services.configure{{/t}}</a></div>{{/needsCredentials}}
{{^needsCredentials}}
{{#server}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-server me-1" aria-hidden="true"></i> {{#t}}mysql.server{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody><tr><th>{{#t}}mysql.version{{/t}}</th><td>{{version}}</td></tr><tr><th>{{#t}}mysql.versionComment{{/t}}</th><td>{{versionComment}}</td></tr><tr><th>{{#t}}mysql.port{{/t}}</th><td>{{port}}</td></tr><tr><th>{{#t}}mysql.datadir{{/t}}</th><td><code>{{datadir}}</code></td></tr><tr><th>{{#t}}mysql.serverTime{{/t}}</th><td>{{now}}</td></tr></tbody></table></div></section>{{/server}}
{{#statusPairs.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-chart-bar me-1" aria-hidden="true"></i> {{#t}}mysql.globalStatus{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}mysql.variable{{/t}}</th><th>{{#t}}mysql.value{{/t}}</th></tr></thead><tbody>{{#statusPairs}}<tr><td>{{key}}</td><td>{{value}}</td></tr>{{/statusPairs}}</tbody></table></div></section>{{/statusPairs.length}}
{{#variablePairs.length}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-cog me-1" aria-hidden="true"></i> {{#t}}mysql.keyVariables{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}mysql.variable{{/t}}</th><th>{{#t}}mysql.value{{/t}}</th></tr></thead><tbody>{{#variablePairs}}<tr><td>{{key}}</td><td>{{value}}</td></tr>{{/variablePairs}}</tbody></table></div></section>{{/variablePairs.length}}
{{#databases}}<section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-layer-group me-1" aria-hidden="true"></i> {{#t}}mysql.databases{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}mysql.databases.header{{/t}}</th><th></th></tr></thead><tbody>{{#databases}}<tr><td><strong>{{name}}</strong></td><td><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/mysql/databases/{{name}}/tables">{{#t}}mysql.databases.browse{{/t}}</a></td></tr>{{/databases}}{{^databases}}<tr><td colspan="2" class="text-secondary">{{#t}}mysql.databases.none{{/t}}</td></tr>{{/databases}}</tbody></table></div></section>{{/databases}}
{{/needsCredentials}}
