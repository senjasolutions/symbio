<!-- PostgreSQL database tables page shows all tables across schemas. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services">{{#t}}server.breadcrumb.services{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{service.serverId}}/services/{{service.id}}">{{#t}}postgresql.breadcrumb{{/t}}</a></li><li class="breadcrumb-item active">{{dbName}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="h3 mb-1"><i class="{{service.serviceIcon}} me-1" aria-hidden="true"></i> {{dbName}}</h1></div></div>
{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
{{#tables.length}}<section class="card"><div class="card-header"><strong>{{#t}}postgresql.tables{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}postgresql.tables.schema{{/t}}</th><th>{{#t}}postgresql.tables.table{{/t}}</th><th>{{#t}}postgresql.tables.type{{/t}}</th><th>{{#t}}postgresql.tables.estimatedRows{{/t}}</th><th>{{#t}}postgresql.tables.size{{/t}}</th><th></th></tr></thead><tbody>{{#tables}}<tr><td><code>{{schema}}</code></td><td><strong>{{name}}</strong></td><td>{{type}}</td><td>{{rowEstimate}}</td><td class="small">{{size}}</td><td><a class="btn btn-outline-primary btn-sm" href="/servers/{{service.serverId}}/services/{{service.id}}/postgresql/databases/{{dbName}}/schemas/{{schema}}/tables/{{name}}/browse">{{#t}}postgresql.databases.browse{{/t}}</a></td></tr>{{/tables}}</tbody></table></div></section>{{/tables.length}}
{{^tables.length}}{{^error}}<section class="card"><div class="card-body text-secondary">{{#t}}postgresql.tables.none{{/t}}</div></section>{{/error}}{{/tables.length}}
