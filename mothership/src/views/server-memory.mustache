<!-- Memory detail reads every /proc/meminfo field with a short description for each kernel-reported memory metric. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.memory.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.memory.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.memory.paraDescription{{/t}} {{#t}}server.memory.totalIs{{/t}} {{memory.total}}{{#memory.total}} ({{memory.total}} {{#t}}common.bytes{{/t}}){{/memory.total}}.</p>
{{#error}}<div class="alert alert-warning" role="alert">{{#t}}common.agentUnavailable{{/t}}</div>{{/error}}
<section class="card"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}server.memory.key{{/t}}</th><th class="text-end">{{#t}}server.memory.value{{/t}}</th><th class="d-none d-lg-table-cell">{{#t}}server.memory.description{{/t}}</th></tr></thead><tbody>{{#detail}}<tr><td class="font-monospace small">{{key}}</td><td class="text-end">{{label}}</td><td class="d-none d-lg-table-cell small text-muted">{{description}}</td></tr>{{/detail}}{{^detail}}<tr><td colspan="3" class="text-muted">{{#t}}server.memory.noData{{/t}}</td></tr>{{/detail}}</tbody></table></div></section>
