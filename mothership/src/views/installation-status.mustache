<!-- Installation Status explains current safe deployment facts without privileged Docker inspection. -->
<div class="d-flex justify-content-between align-items-center mb-3"><div><p class="text-secondary small text-uppercase mb-1">System</p><h1 class="h3 mb-0">Installation Status</h1></div><a class="btn btn-outline-secondary btn-sm" href="/installation-status">Refresh</a></div>
<div class="alert alert-warning"><strong>Beta HTTP warning:</strong> public access on {{publicBinding}} is plaintext. HTTPS is mandatory before production use.</div>
<div class="row g-3"><div class="col-lg-6"><section class="card h-100"><div class="card-header"><strong>Installation</strong></div><table class="table table-sm mb-0"><tbody><tr><th>Version</th><td>{{version}}</td></tr><tr><th>Install path</th><td>/opt/symbio</td></tr><tr><th>Configuration</th><td>/etc/symbio</td></tr><tr><th>Data volumes</th><td>symbio-mothership-data, symbio-agent-data</td></tr><tr><th>Public binding</th><td>{{publicBinding}}</td></tr><tr><th>Private binding</th><td>{{internalBinding}}</td></tr></tbody></table></section></div><div class="col-lg-6"><section class="card h-100"><div class="card-header"><strong>Runtime</strong></div><table class="table table-sm mb-0"><tbody><tr><th>Mothership health</th><td>{{mothershipHealth}}</td></tr><tr><th>Agent health</th><td><span class="badge text-bg-{{agentHealthClass}}">{{agentHealth}}</span></td></tr><tr><th>Last agent report</th><td>{{lastReport}}</td></tr><tr><th>Hardening</th><td>Non-root, read-only filesystems, dropped capabilities, no new privileges.</td></tr><tr><th>Docker inspection</th><td>Unavailable by design: no Docker socket is mounted.</td></tr><tr><th>Systemd inspection</th><td>Unavailable by design: no system D-Bus socket is mounted.</td></tr></tbody></table></section></div></div>
<section class="card mt-3"><div class="card-header"><strong>Migration state</strong></div><table class="table table-sm mb-0"><thead><tr><th>Version</th><th>Name</th><th>Applied</th></tr></thead><tbody>{{#migrations}}<tr><td>{{version}}</td><td>{{name}}</td><td>{{appliedAt}}</td></tr>{{/migrations}}</tbody></table></section>
<section class="card mt-3"><div class="card-header"><strong>Service components</strong></div><table class="table table-sm mb-0"><thead><tr><th>Type</th><th>Status</th><th>Enabled</th><th>Description</th></tr></thead><tbody>{{#components}}<tr><td><i class="{{icon}} me-1" aria-hidden="true"></i>{{displayName}}</td><td><span class="badge text-bg-success">Registered</span></td><td>{{enabled}}</td><td class="text-secondary">{{description}}</td></tr>{{/components}}</tbody></table></section>
