<!-- Installation Status explains current safe deployment facts without privileged Docker inspection. -->
<div class="d-flex justify-content-between align-items-center mb-3"><div><p class="text-secondary small text-uppercase mb-1">{{#t}}nav.system{{/t}}</p><h1 class="h3 mb-0">{{#t}}installation.title{{/t}}</h1></div><a class="btn btn-outline-secondary btn-sm" href="/installation-status">{{#t}}common.refresh{{/t}}</a></div>
<div class="alert alert-warning">{{#t}}installation.betaHttpWarning{{/t}}</div>
<div class="row g-3"><div class="col-lg-6"><section class="card h-100"><div class="card-header"><strong>{{#t}}installation.title{{/t}}</strong></div><table class="table table-sm mb-0"><tbody><tr><th>{{#t}}installation.version{{/t}}</th><td>{{version}}</td></tr><tr><th>{{#t}}installation.installPath{{/t}}</th><td>/opt/symbio</td></tr><tr><th>{{#t}}installation.configPath{{/t}}</th><td>/etc/symbio</td></tr><tr><th>{{#t}}installation.dataVolumes{{/t}}</th><td>symbio-mothership-data, symbio-agent-data</td></tr><tr><th>{{#t}}installation.publicBinding{{/t}}</th><td>{{publicBinding}}</td></tr><tr><th>{{#t}}installation.internalBinding{{/t}}</th><td>{{internalBinding}}</td></tr></tbody></table></section></div><div class="col-lg-6"><section class="card h-100"><div class="card-header"><strong>{{#t}}installation.runtime{{/t}}</strong></div><table class="table table-sm mb-0"><tbody><tr><th>{{#t}}installation.mothershipHealth{{/t}}</th><td>{{mothershipHealth}}</td></tr><tr><th>{{#t}}installation.agentHealth{{/t}}</th><td><span class="badge text-bg-{{agentHealthClass}}">{{agentHealth}}</span></td></tr><tr><th>{{#t}}installation.lastReport{{/t}}</th><td>{{lastReport}}</td></tr><tr><th>{{#t}}installation.hardening{{/t}}</th><td>{{#t}}installation.hardeningDetail{{/t}}</td></tr><tr><th>{{#t}}installation.dockerInspection{{/t}}</th><td>{{#t}}installation.dockerDetail{{/t}}</td></tr><tr><th>{{#t}}installation.systemdInspection{{/t}}</th><td>{{#t}}installation.systemdDetail{{/t}}</td></tr></tbody></table></section></div></div>
<section class="card mt-3"><div class="card-header"><strong>{{#t}}installation.migrations{{/t}}</strong></div><table class="table table-sm mb-0"><thead><tr><th>{{#t}}installation.migrationVersion{{/t}}</th><th>{{#t}}installation.migrationName{{/t}}</th><th>{{#t}}installation.migrationAppliedAt{{/t}}</th></tr></thead><tbody>{{#migrations}}<tr><td>{{version}}</td><td>{{name}}</td><td>{{appliedAt}}</td></tr>{{/migrations}}</tbody></table></section>
<section class="card mt-3"><div class="card-header"><strong>{{#t}}installation.components{{/t}}</strong></div><table class="table table-sm mb-0"><thead><tr><th>{{#t}}installation.componentType{{/t}}</th><th>{{#t}}applications.status{{/t}}</th><th>{{#t}}installation.enabled{{/t}}</th><th>{{#t}}installation.componentDescription{{/t}}</th></tr></thead><tbody>{{#components}}<tr><td><i class="{{icon}} me-1" aria-hidden="true"></i>{{displayName}}</td><td><span class="badge text-bg-success">{{#t}}installation.registered{{/t}}</span></td><td>{{enabled}}</td><td class="text-secondary">{{description}}</td></tr>{{/components}}</tbody></table></section>
