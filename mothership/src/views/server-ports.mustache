<!-- Listening ports show TCP and UDP sockets and the owning process where resolvable. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.ports.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.ports.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.ports.description{{/t}}</p>
{{#error}}<div class="alert alert-warning" role="alert">{{#t}}common.agentUnavailable{{/t}}</div>{{/error}}

<form class="row g-2 mb-3" method="get">
  <div class="col-sm-8 col-md-6 col-lg-5">
    <div class="input-group input-group-sm">
      <span class="input-group-text"><i class="fa-solid fa-search" aria-hidden="true"></i></span>
      <input class="form-control" type="text" name="q" value="{{query}}" placeholder="{{#t}}server.ports.searchPlaceholder{{/t}}">
      {{#query}}<a class="btn btn-outline-secondary" href="?page=1"><i class="fa-solid fa-xmark" aria-hidden="true"></i></a>{{/query}}
      <button class="btn btn-primary" type="submit">{{#t}}server.ports.search{{/t}}</button>
    </div>
  </div>
  {{#showing}}<div class="col-sm-4 col-md-6 col-lg-7 text-end small pt-1 text-muted">{{#t}}server.ports.total{{/t}}</div>{{/showing}}
</form>

<section class="card"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}server.ports.protocol{{/t}}</th><th>{{#t}}server.ports.localAddress{{/t}}</th><th>{{#t}}server.ports.localPort{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.ports.state{{/t}}</th><th>{{#t}}server.ports.process{{/t}}</th><th>{{#t}}server.ports.pid{{/t}}</th></tr></thead><tbody>{{#ports}}<tr><td><span class="badge text-bg-secondary">{{protocol}}</span></td><td class="font-monospace small">{{localAddr}}</td><td>{{localPort}}</td><td class="d-none d-md-table-cell">{{state}}</td><td class="font-monospace small">{{processName}}</td><td>{{pid}}</td></tr>{{/ports}}{{^ports}}<tr><td colspan="6" class="text-muted">{{#query}}{{#t}}server.ports.noResults{{/t}}{{/query}}{{^query}}{{#t}}server.ports.none{{/t}}{{/query}}</td></tr>{{/ports}}</tbody></table></div></section>

{{#totalPages}}{{#showPagination}}<nav class="d-flex justify-content-between align-items-center mt-3" aria-label="{{#t}}common.pagination{{/t}}">
  <small class="text-muted">{{#t}}common.pageOf{{/t}}</small>
  <ul class="pagination pagination-sm mb-0">
    {{#page}}{{#isFirst}}<li class="page-item disabled"><span class="page-link">&laquo;</span></li>{{/isFirst}}{{^isFirst}}<li class="page-item"><a class="page-link" href="?page={{prevPage}}{{#query}}&q={{query}}{{/query}}">&laquo;</a></li>{{/isFirst}}{{/page}}
    {{#pages}}<li class="page-item {{#active}}active{{/active}}"><a class="page-link" href="?page={{num}}{{#query}}&q={{query}}{{/query}}">{{num}}</a></li>{{/pages}}
    {{#page}}{{#isLast}}<li class="page-item disabled"><span class="page-link">&raquo;</span></li>{{/isLast}}{{^isLast}}<li class="page-item"><a class="page-link" href="?page={{nextPage}}{{#query}}&q={{query}}{{/query}}">&raquo;</a></li>{{/isLast}}{{/page}}
  </ul>
</nav>{{/showPagination}}{{/totalPages}}
