<!-- Logged-in users shows active sessions parsed from /var/run/utmp on the host. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">Servers</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">Logged-in Users</li></ol></nav>
<h1 class="h3 mb-1">Logged-in Users</h1>
<p class="text-secondary small mb-3">Active user sessions detected on the host. Data is parsed from /var/run/utmp and shows traditional login sessions (not SSH daemon accounting).</p>
{{#error}}<div class="alert alert-warning" role="alert">Agent unavailable: {{error}}</div>{{/error}}
<section class="card"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>User</th><th>Terminal</th><th class="d-none d-md-table-cell">Login Time</th><th class="d-none d-lg-table-cell">Source Host</th></tr></thead><tbody>{{#users}}<tr><td class="fw-bold">{{user}}</td><td class="font-monospace small">{{terminal}}</td><td class="d-none d-md-table-cell">{{loginLabel}}</td><td class="d-none d-lg-table-cell">{{host}}</td></tr>{{/users}}{{^users}}<tr><td colspan="4" class="text-muted">No active user sessions detected.</td></tr>{{/users}}</tbody></table></div></section>
