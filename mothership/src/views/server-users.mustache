<!-- Logged-in users shows active sessions parsed from /var/run/utmp on the host. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.users.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.users.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.users.description{{/t}}</p>
{{#error}}<div class="alert alert-warning" role="alert">{{#t}}common.agentUnavailable{{/t}}</div>{{/error}}
<section class="card"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}server.users.user{{/t}}</th><th>{{#t}}server.users.terminal{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.users.loginTime{{/t}}</th><th class="d-none d-lg-table-cell">{{#t}}server.users.sourceHost{{/t}}</th></tr></thead><tbody>{{#users}}<tr><td class="fw-bold">{{user}}</td><td class="font-monospace small">{{terminal}}</td><td class="d-none d-md-table-cell">{{loginLabel}}</td><td class="d-none d-lg-table-cell">{{host}}</td></tr>{{/users}}{{^users}}<tr><td colspan="4" class="text-muted">{{#t}}server.users.none{{/t}}</td></tr>{{/users}}</tbody></table></div></section>
