<!-- Fix Guide — AI-generated step-by-step tutorial for manually fixing a finding. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/ai">{{#t}}ai.symbioIntelligence{{/t}}</a></li><li class="breadcrumb-item"><a href="/ai/actions">{{#t}}ai.pendingActions{{/t}}</a></li><li class="breadcrumb-item active">{{#t}}ai.fixGuide{{/t}}</li></ol></nav>

<h1 class="h3 mb-3"><i class="fa-solid fa-wrench me-1" aria-hidden="true"></i>{{#t}}ai.fixGuide{{/t}}</h1>

<section class="card mb-3">
  <div class="card-header"><strong>{{#t}}ai.clarifyOriginal{{/t}}</strong></div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-sm-3"><small class="text-secondary d-block">{{#t}}ai.skill{{/t}}</small><span>{{#skillIconImg}}<img src="{{skillIcon}}" style="width:16px;height:16px;vertical-align:middle;margin-right:4px;">{{/skillIconImg}}{{^skillIconImg}}<i class="{{skillIcon}} me-1"></i>{{/skillIconImg}}{{skillName}}</span></div>
      <div class="col-sm-3"><small class="text-secondary d-block">{{#t}}ai.severity{{/t}}</small><span class="badge {{severityBadge}}">{{severity}}</span></div>
      <div class="col-sm-3"><small class="text-secondary d-block">{{#t}}ai.source{{/t}}</small><span>{{source}}</span></div>
      {{#pattern}}<div class="col-sm-3"><small class="text-secondary d-block">{{#t}}ai.pattern{{/t}}</small><code>{{pattern}}</code></div>{{/pattern}}
      {{#findingTitle}}<div class="col-12"><small class="text-secondary d-block">{{#t}}ai.message{{/t}}</small><p class="mb-0">{{findingTitle}}</p></div>{{/findingTitle}}
      {{#findingDescription}}<div class="col-12"><small class="text-secondary d-block">{{#t}}ai.detail{{/t}}</small><p class="mb-0 text-secondary">{{findingDescription}}</p></div>{{/findingDescription}}
    </div>
  </div>
</section>

<section class="card mb-3">
  <div class="card-header"><strong><i class="fa-solid fa-list-ol me-1"></i>{{#t}}ai.fixGuideTitle{{/t}}</strong></div>
  <div class="card-body">
    {{#guideHtml}}
    <div class="border rounded p-3 bg-light" style="font-size:0.9rem;line-height:1.6;">{{{guideHtml}}}</div>
    {{/guideHtml}}
    {{#error}}
    <div class="alert alert-danger mb-0">{{error}}</div>
    {{/error}}
  </div>
</section>

<section class="card mb-3">
  <div class="card-header"><strong><i class="fa-solid fa-database me-1"></i>{{#t}}ai.fixContextTitle{{/t}}</strong></div>
  <div class="card-body">
    <details>
      <summary class="text-secondary small">{{#t}}ai.fixContextToggle{{/t}}</summary>
      <pre class="small mt-2 mb-0" style="max-height:300px;overflow-y:auto;white-space:pre-wrap;">{{serverContext}}</pre>
    </details>
  </div>
</section>

<div class="d-flex gap-2">
  <a class="btn btn-outline-secondary" href="/ai/actions">{{#t}}ai.handleBack{{/t}}</a>
  <form class="d-inline" method="post" action="/ai/actions/{{actionId}}/guide">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <input type="hidden" name="action" value="dismiss">
    <button class="btn btn-outline-danger btn-sm" type="submit"><i class="fa-solid fa-ban me-1"></i>{{#t}}ai.dismiss{{/t}}</button>
  </form>
  <form class="d-inline" method="post" action="/ai/actions/{{actionId}}/guide">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <input type="hidden" name="action" value="done">
    <button class="btn btn-success" type="submit"><i class="fa-solid fa-check me-1"></i>{{#t}}ai.fixGuideDone{{/t}}</button>
  </form>
</div>
