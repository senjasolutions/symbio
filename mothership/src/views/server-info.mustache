<!-- Server information collects CPU, OS, memory, and boot details for a complete system profile. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.info.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.info.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.info.description{{/t}}</p>
{{#error}}<div class="alert alert-warning" role="alert">{{#t}}common.agentUnavailable{{/t}}</div>{{/error}}
<div class="row g-3">
  <div class="col-lg-6">
    <section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-laptop me-1" aria-hidden="true"></i>{{#t}}server.info.os{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>
      <tr><th>{{#t}}server.info.os{{/t}}</th><td>{{info.os}}</td></tr>
      <tr><th>{{#t}}server.info.osId{{/t}}</th><td>{{info.osId}}{{#info.osVersion}} {{info.osVersion}}{{/info.osVersion}}</td></tr>
      <tr><th>{{#t}}server.info.hostname{{/t}}</th><td>{{server.hostname}}</td></tr>
      <tr><th>{{#t}}server.info.primaryIp{{/t}}</th><td>{{server.primaryIp}}</td></tr>
      <tr><th>{{#t}}server.info.kernel{{/t}}</th><td>{{server.kernelVersion}}</td></tr>
      <tr><th>{{#t}}server.info.architecture{{/t}}</th><td>{{server.hardware.architecture}}</td></tr>
    </tbody></table></div></section>
    <section class="card"><div class="card-header"><strong><i class="fa-solid fa-clock me-1" aria-hidden="true"></i>{{#t}}server.info.uptimeBoot{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>
      <tr><th>{{#t}}server.info.bootTime{{/t}}</th><td>{{info.bootTime}}{{#info.bootTime}} {{#t}}server.info.secondsAgo{{/t}}{{/info.bootTime}}</td></tr>
    </tbody></table></div></section>
  </div>
  <div class="col-lg-6">
    <section class="card mb-3"><div class="card-header"><strong><i class="fa-solid fa-microchip me-1" aria-hidden="true"></i>{{#t}}server.info.cpu{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>
      <tr><th>{{#t}}server.info.model{{/t}}</th><td>{{info.cpu.model}}</td></tr>
      <tr><th>{{#t}}server.info.cores{{/t}}</th><td>{{info.cpu.cores}} {{#t}}server.info.physical{{/t}}</td></tr>
      <tr><th>{{#t}}server.info.threads{{/t}}</th><td>{{info.cpu.threads}} {{#t}}server.info.logical{{/t}}</td></tr>
      <tr><th>{{#t}}server.info.frequency{{/t}}</th><td>{{info.cpu.mhz}} {{#t}}server.info.megahertz{{/t}}</td></tr>
      <tr><th>{{#t}}server.info.l3Cache{{/t}}</th><td>{{info.cpu.cacheL3}}</td></tr>
    </tbody></table></div></section>
    <section class="card"><div class="card-header"><strong><i class="fa-solid fa-memory me-1" aria-hidden="true"></i>{{#t}}server.info.memory{{/t}}</strong></div><div class="table-responsive"><table class="table table-sm mb-0"><tbody>
      <tr><th>{{#t}}server.info.totalRam{{/t}}</th><td>{{info.memory.totalLabel}}</td></tr>
      <tr><th>{{#t}}server.info.totalSwap{{/t}}</th><td>{{info.memory.swapLabel}}</td></tr>
    </tbody></table></div></section>
  </div>
</div>
