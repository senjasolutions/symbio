<!-- Resource usage charts render CPU, memory, and disk history with a 24-hour or 7-day range selector. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.charts.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.charts.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.charts.description{{/t}}</p>
<div class="btn-group mb-3"><a class="btn btn-outline-primary {{#range.is24h}}active{{/range.is24h}}" href="?range=24h">{{#t}}server.charts.range24h{{/t}}</a><a class="btn btn-outline-primary {{#range.is7d}}active{{/range.is7d}}" href="?range=7d">{{#t}}server.charts.range7d{{/t}}</a></div>
<div class="row g-3 mb-4"><div class="col-12">{{{cpuChart}}}</div><div class="col-lg-6">{{{memoryChart}}}</div><div class="col-lg-6">{{{diskChart}}}</div></div>
