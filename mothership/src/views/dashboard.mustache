<!-- i18n: all visible labels use {{#t}}key{{/t}}. Variable placeholders in translations match template data property names (e.g. {{cpuAverages.average5m}}). -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><p class="text-secondary small text-uppercase mb-1">{{#t}}dashboard.overview{{/t}}</p><h1 class="h3 mb-0">{{#t}}dashboard.title{{/t}}</h1></div>
  <a class="btn btn-outline-secondary btn-sm" href="/dashboard">{{#t}}dashboard.refresh{{/t}}</a>
</div>
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body"><div class="text-secondary small">{{#t}}dashboard.mainServer{{/t}}</div><div class="metric-value text-{{stateClass}}" data-summary-key="serverState">{{#serverOnline}}<i class="fa-solid fa-square-check" aria-hidden="true"></i>{{/serverOnline}}{{#serverOffline}}<i class="fa-solid fa-square-xmark" aria-hidden="true"></i>{{/serverOffline}} {{state}}</div><div class="small text-secondary mt-2">{{#t}}dashboard.lastReport{{/t}}</div> <a href="/servers/1"><button class="w-100 btn btn-primary center">{{#t}}dashboard.moreInfo{{/t}}</button></a></div></div></div>
  <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body metric-card"><div><div class="text-secondary small"><i class="fa-solid fa-microchip"></i> {{#t}}dashboard.cpu{{/t}}</div><div class="metric-value" data-summary-key="cpuPercent">{{cpuPercent}}</div><small class="metric-detail">{{#t}}dashboard.cpuAverage{{/t}}</small></div>{{{cpuRing}}}</div></div></div>
  <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body metric-card"><div><div class="text-secondary small"><i class="fa-solid fa-memory"></i> {{#t}}dashboard.memory{{/t}}</div><div class="metric-value" data-summary-key="memoryPercent">{{memoryPercent}}</div><small class="metric-capacity">{{memoryAmount}}</small><small class="metric-detail">{{#t}}dashboard.memoryAverage{{/t}}</small></div>{{{memoryRing}}}</div></div></div>
  <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body metric-card"><div><div class="text-secondary small"><i class="fa-solid fa-hard-drive"></i> {{#t}}dashboard.rootDisk{{/t}}</div><div class="metric-value" data-summary-key="diskPercent">{{diskPercent}}</div><small class="metric-capacity">{{diskAmount}}</small></div>{{{diskRing}}}</div></div></div>
</div>
<!-- Server-rendered SVG charts: 6-hour trend grouped by server average -->
<div class="row g-3 mb-4">
  <div class="col-12">{{{cpuChart}}}</div>
  <div class="col-lg-6">{{{memoryChart}}}</div>
  <div class="col-lg-6">{{{diskChart}}}</div>
</div>
<div class="row g-3">
  <div class="col-lg-6"><section class="card"><div class="card-header d-flex justify-content-between"><strong>{{#t}}dashboard.services{{/t}}</strong><a href="/servers/{{server.id}}/services">{{#t}}dashboard.viewAll{{/t}}</a></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}dashboard.service{{/t}}</th><th>{{#t}}dashboard.status{{/t}}</th></tr></thead><tbody>{{#services}}<tr><td><i class="{{serviceIcon}} me-1" aria-hidden="true"></i><a href="/servers/{{server_id}}/services/{{id}}">{{display_name}}</a></td><td><span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span></td></tr>{{/services}}{{^services}}<tr><td colspan="2">{{#t}}dashboard.noServices{{/t}}</td></tr>{{/services}}</tbody></table></div></section></div>
  <div class="col-lg-6"><section class="card"><div class="card-header d-flex justify-content-between"><strong>{{#t}}dashboard.applications{{/t}}</strong><a href="/applications">{{#t}}dashboard.viewAll{{/t}}</a></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr>        <th>{{#t}}dashboard.application{{/t}}</th><th>{{#t}}dashboard.status{{/t}}</th><th>{{#t}}dashboard.response{{/t}}</th></tr></thead><tbody>{{#applications}}<tr><td><a href="/applications/{{id}}">{{display_name}}</a></td><td><span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span></td><td>{{responseTimeLabel}}</td></tr>{{/applications}}{{^applications}}<tr><td colspan="3">{{#t}}dashboard.noApplications{{/t}}</td></tr>{{/applications}}</tbody></table></div></section></div>
</div>
