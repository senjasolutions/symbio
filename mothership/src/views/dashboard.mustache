<!-- Dashboard summarizes the freshest host, service, and application evidence. -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><p class="text-secondary small text-uppercase mb-1">Overview</p><h1 class="h3 mb-0">Dashboard</h1></div>
  <a class="btn btn-outline-secondary btn-sm" href="/dashboard">Refresh</a>
</div>
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body"><div class="text-secondary small">Main Server</div><div class="metric-value text-{{stateClass}}" data-summary-key="serverState">{{#serverOnline}}<i class="fa-solid fa-square-check" aria-hidden="true"></i>{{/serverOnline}}{{#serverOffline}}<i class="fa-solid fa-square-xmark" aria-hidden="true"></i>{{/serverOffline}} {{state}}</div><div class="small text-secondary mt-2">Last report: {{lastSeenAt}}</div></div></div></div>
  <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body metric-card"><div><div class="text-secondary small"><i class="fa-solid fa-microchip"></i> CPU</div><div class="metric-value" data-summary-key="cpuPercent">{{cpuPercent}}</div><small class="metric-detail">5m {{cpuAverages.average5m}} · 30m {{cpuAverages.average30m}} · 6h {{cpuAverages.average6h}}</small></div>{{{cpuRing}}}</div></div></div>
  <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body metric-card"><div><div class="text-secondary small"><i class="fa-solid fa-memory"></i> Memory</div><div class="metric-value" data-summary-key="memoryPercent">{{memoryPercent}}</div><small class="metric-capacity">{{memoryAmount}}</small><small class="metric-detail">5m {{memoryAverages.average5m}} · 30m {{memoryAverages.average30m}} · 6h {{memoryAverages.average6h}}</small></div>{{{memoryRing}}}</div></div></div>
  <div class="col-sm-6 col-xl-3"><div class="card h-100"><div class="card-body metric-card"><div><div class="text-secondary small"><i class="fa-solid fa-hard-drive"></i> Root Disk</div><div class="metric-value" data-summary-key="diskPercent">{{diskPercent}}</div><small class="metric-capacity">{{diskAmount}}</small></div>{{{diskRing}}}</div></div></div>
</div>
<div class="row g-3">
  <div class="col-lg-6"><section class="card"><div class="card-header d-flex justify-content-between"><strong>Services</strong><a href="/servers/{{server.id}}/services">View all</a></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Service</th><th>Status</th></tr></thead><tbody>{{#services}}<tr><td><i class="{{serviceIcon}} me-1" aria-hidden="true"></i><a href="/servers/{{server_id}}/services/{{id}}">{{display_name}}</a></td><td><span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span></td></tr>{{/services}}{{^services}}<tr><td colspan="2">No service data.</td></tr>{{/services}}</tbody></table></div></section></div>
  <div class="col-lg-6"><section class="card"><div class="card-header d-flex justify-content-between"><strong>Applications</strong><a href="/applications">View all</a></div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Application</th><th>Status</th><th>Response</th></tr></thead><tbody>{{#applications}}<tr><td><a href="/applications/{{id}}">{{display_name}}</a></td><td><span class="badge text-bg-{{statusClass}} status-badge">{{status}}</span></td><td>{{responseTimeLabel}}</td></tr>{{/applications}}{{^applications}}<tr><td colspan="3">No applications configured.</td></tr>{{/applications}}</tbody></table></div></section></div>
</div>
