<!-- Lists Symbio self-monitoring log sources (mothership + agent). -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.symbioLogs.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.symbioLogs.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.symbioLogs.description{{/t}}</p>
<section class="card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>{{#t}}server.symbioLogs.component{{/t}}</th><th>{{#t}}server.symbioLogs.description{{/t}}</th><th></th></tr></thead><tbody>{{#sources}}<tr><td><strong>{{displayName}}</strong></td><td>{{description}}</td><td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/servers/{{server.id}}/monitoring/logs/symbio/view?source={{slug}}">{{#t}}application.detail.view{{/t}}</a></td></tr>{{/sources}}{{^sources}}<tr><td colspan="2" class="text-muted">{{#t}}server.symbioLogs.noLogs{{/t}}</td></tr>{{/sources}}</tbody></table></div></section>
