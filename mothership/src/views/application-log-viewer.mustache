<!-- The viewer has a complete server-rendered refresh form; JavaScript only adds polling and scrolling. -->
<nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/applications">{{#t}}nav.applications{{/t}}</a></li><li class="breadcrumb-item"><a href="/applications/{{application.id}}">{{application.displayName}}</a></li><li class="breadcrumb-item active">{{log.displayName}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-start mb-3"><div><h1 class="h3 mb-1"><i class="fa-solid fa-file-lines me-1" aria-hidden="true"></i>{{log.displayName}}</h1><p class="text-secondary mb-0"><code>{{log.filePath}}</code></p></div>{{^deleted}}<div><a class="btn btn-outline-secondary btn-sm" href="/applications/{{application.id}}/logs/{{log.id}}/edit">{{#t}}application.log.viewer.editSource{{/t}}</a></div>{{/deleted}}</div>
{{#error}}<div class="alert alert-danger" role="alert">{{error}}</div>{{/error}}
<section class="card mb-3" data-log-viewer data-content-url="/applications/{{application.id}}/logs/{{log.id}}/content"><div class="card-body"><form class="d-flex flex-wrap align-items-end gap-2" method="get" action="/applications/{{application.id}}/logs/{{log.id}}"><div><label class="form-label mb-1" for="tailLimit">{{#t}}application.log.viewer.tailLabel{{/t}}</label><select class="form-select form-select-sm" id="tailLimit" name="limit" data-tail-limit>{{#tailChoices}}<option value="{{value}}" {{#selected}}selected{{/selected}}>{{#t}}application.log.form.linesOption{{/t}}</option>{{/tailChoices}}</select></div><button class="btn btn-primary btn-sm" type="submit"><i class="fa-solid fa-rotate" aria-hidden="true"></i> {{#t}}application.log.viewer.refresh{{/t}}</button><div class="form-check form-switch mb-1"><input class="form-check-input" id="autoRefresh" type="checkbox" data-auto-refresh><label class="form-check-label" for="autoRefresh">{{#t}}application.log.viewer.autoRefresh{{/t}}</label></div><div class="form-check form-switch mb-1"><input class="form-check-input" id="autoScroll" type="checkbox" checked data-auto-scroll><label class="form-check-label" for="autoScroll">{{#t}}application.log.viewer.autoScroll{{/t}}</label></div></form></div></section>
<pre class="log-output" tabindex="0" data-log-output>{{logContent}}</pre>
<p class="text-secondary small mb-0" data-log-status>{{#t}}application.log.viewer.status{{/t}}</p>
<script>
  /* Progressive refresh is deliberately local to the viewer; the SSR form remains the no-JS fallback. */
  (() => {
    const viewer = document.querySelector("[data-log-viewer]"); if (!viewer || !window.fetch) return;
    const output = document.querySelector("[data-log-output]"), status = document.querySelector("[data-log-status]"), limit = viewer.querySelector("[data-tail-limit]"), autoRefresh = viewer.querySelector("[data-auto-refresh]"), autoScroll = viewer.querySelector("[data-auto-scroll]");
    const read = (key, fallback) => { try { const value = localStorage.getItem(key); return value === null ? fallback : value === "1"; } catch { return fallback; } };
    const write = (key, value) => { try { localStorage.setItem(key, value ? "1" : "0"); } catch {} };
    let loading = false, timer = null;
    const refresh = async () => { if (loading || document.hidden) return; loading = true; status.textContent = "Refreshing…"; try { const response = await fetch(`${viewer.dataset.contentUrl}?limit=${encodeURIComponent(limit.value)}`, { credentials: "same-origin" }); const body = await response.json(); if (!response.ok || !body.ok) throw new Error(body.error || "Failed to read log."); output.textContent = body.text || "(no output)"; if (autoScroll.checked) output.scrollTop = output.scrollHeight; status.textContent = `Last read: ${new Date(body.readAt).toLocaleString()} · ${body.bytes} bytes${body.truncated ? " · Output truncated" : ""}`; } catch (error) { status.textContent = error.message; } finally { loading = false; } };
    const schedule = () => { if (timer) clearInterval(timer); timer = autoRefresh.checked ? setInterval(refresh, 10_000) : null; };
    autoRefresh.checked = read("symbio-log-auto-refresh", false); autoScroll.checked = read("symbio-log-auto-scroll", true); schedule();
    autoRefresh.addEventListener("change", () => { write("symbio-log-auto-refresh", autoRefresh.checked); schedule(); }); autoScroll.addEventListener("change", () => write("symbio-log-auto-scroll", autoScroll.checked));
    document.addEventListener("visibilitychange", () => { if (!document.hidden && autoRefresh.checked) refresh(); });
  })();
</script>
<form class="card mt-3" method="post" action="/applications/{{application.id}}/logs/{{log.id}}/search"><div class="card-body"><input type="hidden" name="_csrf" value="{{csrfToken}}"><label class="form-label" for="query">{{#t}}application.log.viewer.searchLabel{{/t}}</label><div class="input-group"><input class="form-control" id="query" name="query" maxlength="500" required placeholder="{{#t}}application.log.viewer.searchPlaceholder{{/t}}"><button class="btn btn-outline-primary" type="submit"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i> {{#t}}application.log.viewer.search{{/t}}</button></div><div class="form-text">{{#t}}application.log.viewer.searchHelp{{/t}}</div></div></form>
{{^deleted}}<form class="mt-3" method="post" action="/applications/{{application.id}}/logs/{{log.id}}/delete" data-confirm="{{#t}}application.log.viewer.deleteConfirm{{/t}}"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-outline-danger btn-sm" type="submit">{{#t}}application.log.viewer.deleteSource{{/t}}</button></form>{{/deleted}}
