<!-- Process list reads /proc for every running process and displays them sorted by memory. -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.processes.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.processes.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.processes.description{{/t}}</p>
{{#error}}<div class="alert alert-warning" role="alert">{{#t}}common.agentUnavailable{{/t}}</div>{{/error}}

<!-- Search bar -->
<form class="row g-2 mb-3" method="get">
  <div class="col-sm-8 col-md-6 col-lg-5">
    <div class="input-group input-group-sm">
      <span class="input-group-text"><i class="fa-solid fa-search" aria-hidden="true"></i></span>
      <input class="form-control" type="text" name="q" value="{{query}}" placeholder="{{#t}}server.processes.searchPlaceholder{{/t}}">
      {{#query}}<a class="btn btn-outline-secondary" href="?page=1"><i class="fa-solid fa-xmark" aria-hidden="true"></i></a>{{/query}}
      <button class="btn btn-primary" type="submit">{{#t}}server.processes.search{{/t}}</button>
    </div>
  </div>
  {{#showing}}<div class="col-sm-4 col-md-6 col-lg-7 text-end small pt-1 text-muted">{{#t}}server.processes.total{{/t}}</div>{{/showing}}
</form>

<section class="card"><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>{{#t}}server.processes.pid{{/t}}</th><th>{{#t}}server.processes.user{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.processes.state{{/t}}</th><th>{{#t}}server.processes.rss{{/t}}</th><th class="d-none d-lg-table-cell">{{#t}}server.processes.vsz{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.processes.threads{{/t}}</th><th>{{#t}}server.processes.command{{/t}}</th></tr></thead><tbody>{{#processes}}<tr><td>{{pid}}</td><td>{{user}}</td><td class="d-none d-md-table-cell"><span class="badge text-bg-{{#stateIsRunning}}success{{/stateIsRunning}}{{^stateIsRunning}}secondary{{/stateIsRunning}}">{{state}}</span></td><td>{{rssLabel}}</td><td class="d-none d-lg-table-cell">{{vsizeLabel}}</td><td class="d-none d-md-table-cell">{{threads}}</td><td class="font-monospace small">{{command}}</td></tr>{{/processes}}{{^processes}}<tr><td colspan="7" class="text-muted">{{#query}}{{#t}}server.processes.noResults{{/t}}{{/query}}{{^query}}{{#t}}server.processes.none{{/t}}{{/query}}</td></tr>{{/processes}}</tbody></table></div></section>

<!-- Pagination -->
{{#totalPages}}{{#showPagination}}<nav class="d-flex justify-content-between align-items-center mt-3" aria-label="{{#t}}common.pagination{{/t}}">
  <small class="text-muted">{{#t}}common.pageOf{{/t}}</small>
  <ul class="pagination pagination-sm mb-0">
    {{#page}}{{#isFirst}}<li class="page-item disabled"><span class="page-link">&laquo;</span></li>{{/isFirst}}{{^isFirst}}<li class="page-item"><a class="page-link" href="?page={{prevPage}}{{#query}}&q={{query}}{{/query}}">&laquo;</a></li>{{/isFirst}}{{/page}}
    {{#pages}}<li class="page-item {{#active}}active{{/active}}"><a class="page-link" href="?page={{num}}{{#query}}&q={{query}}{{/query}}">{{num}}</a></li>{{/pages}}
    {{#page}}{{#isLast}}<li class="page-item disabled"><span class="page-link">&raquo;</span></li>{{/isLast}}{{^isLast}}<li class="page-item"><a class="page-link" href="?page={{nextPage}}{{#query}}&q={{query}}{{/query}}">&raquo;</a></li>{{/isLast}}{{/page}}
  </ul>
</nav>{{/showPagination}}{{/totalPages}}
