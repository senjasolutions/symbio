<!-- File content viewer renders monospace text with line numbers, proper formatting, and no modification of whitespace. -->
<nav aria-label="{{#t}}nav.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}server.breadcrumb.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}/file-manager?path={{parentDir}}">{{#t}}server.breadcrumb.fileManager{{/t}}</a></li><li class="breadcrumb-item active">{{fileName}}</li></ol></nav>
<div class="d-flex justify-content-between align-items-start mb-3"><div><h1 class="h3 mb-1">{{filePath}}</h1><p class="text-secondary small mb-0">{{fileSize}} · {{lineCount}} {{#t}}fileViewer.linesLabel{{/t}}</p></div><a class="btn btn-outline-primary btn-sm" href="/servers/{{server.id}}/file-manager?path={{parentDir}}"><i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i>{{#t}}common.back{{/t}}</a></div>
{{#error}}<div class="alert alert-warning" role="alert">{{error}}</div>{{/error}}
{{^error}}
<section class="card"><div class="card-body p-0"><div class="file-viewer"><div class="file-lines">{{#lines}}<span class="file-ln">{{n}}</span>
{{/lines}}</div><pre class="file-text">{{#lines}}{{text}}
{{/lines}}</pre></div></div></section>
{{#truncated}}<div class="alert alert-warning small mt-2">{{#t}}fileViewer.truncated{{/t}}{{#totalBytes}}: {{totalBytes}} bytes{{/totalBytes}}</div>{{/truncated}}
{{/error}}
