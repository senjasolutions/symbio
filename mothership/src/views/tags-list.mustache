<!-- Tag management prevents deletion while assignments still depend on a tag. -->
<div class="d-flex justify-content-between align-items-center mb-3"><div><p class="text-secondary small text-uppercase mb-1">Applications</p><h1 class="h3 mb-0">Application Tags</h1></div><a class="btn btn-primary" href="/application-tags/new">Add Tag</a></div>
{{#error}}<div class="alert alert-danger">{{error}}</div>{{/error}}
<section class="card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Name</th><th>Applications</th><th></th></tr></thead><tbody>{{#tags}}<tr><td>{{name}}</td><td>{{applicationCount}}</td><td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/application-tags/{{id}}/edit">Edit</a> <form class="d-inline" method="post" action="/application-tags/{{id}}/delete"><input type="hidden" name="_csrf" value="{{csrfToken}}"><button class="btn btn-outline-danger btn-sm" type="submit">Delete</button></form></td></tr>{{/tags}}{{^tags}}<tr><td colspan="3">No tags configured.</td></tr>{{/tags}}</tbody></table></div></section>
