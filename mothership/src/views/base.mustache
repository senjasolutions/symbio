<!-- Shared clean-room administrative shell keeps navigation, security warnings, and SSR fallback consistent. -->
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}}</title>
  <link rel="stylesheet" href="/vendor/bootstrap.min.css">
  <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
  <link rel="stylesheet" href="/vendor/tagify.css">
  <link rel="stylesheet" href="/assets/styles.css">
</head>
<body>
  {{#insecureHttp}}<div class="warning-banner"><strong>Beta warning:</strong> this dashboard is using unencrypted HTTP. Do not treat direct public access as production-secure.</div>{{/insecureHttp}}
  {{#authenticated}}
  <div class="app-shell">
    <aside class="sidebar" id="primary-navigation">
      <div class="sidebar-header">
        <a class="sidebar-brand" href="/dashboard"><span>SYMBIO</span></a>
      </div>
      <button class="sidebar-toggle" type="button" data-menu-toggle aria-controls="primary-navigation" aria-expanded="true"><i class="fa-solid fa-bars" aria-hidden="true"></i> Menu</button>
      <nav class="sidebar-nav" aria-label="Primary navigation">
        <div class="nav-group">
          <p class="nav-group-title">Monitoring</p>
          <a class="nav-link {{#dashboardActive}}is-active{{/dashboardActive}}" href="/dashboard"><i class="fa-solid fa-gauge" aria-hidden="true"></i> Dashboard</a>
          <a class="nav-link {{#serversActive}}is-active{{/serversActive}}" href="/servers/1"><i class="fa-solid fa-server" aria-hidden="true"></i> Servers</a>
          <a class="nav-link {{#applicationsActive}}is-active{{/applicationsActive}}" href="/applications"><i class="fa-solid fa-window-maximize" aria-hidden="true"></i> Applications</a>
          <a class="nav-link nav-submenu {{#tagsActive}}is-active{{/tagsActive}}" href="/application-tags"><i class="fa-solid fa-tags" aria-hidden="true"></i> Application Tags</a>
        </div>
        <div class="nav-group">
          <p class="nav-group-title">System</p>
          <a class="nav-link {{#installationActive}}is-active{{/installationActive}}" href="/installation-status"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> Installation Status</a>
          <a class="nav-link {{#settingsActive}}is-active{{/settingsActive}}" href="/settings"><i class="fa-solid fa-gear" aria-hidden="true"></i> Settings</a>
        </div>
      </nav>
    </aside>
    <div class="main-column">
      <header class="topbar">
        <div class="topbar-context"><i class="fa-solid fa-server" aria-hidden="true"></i><span><strong>Main Server</strong></span></div>
        <form class="user-controls" method="post" action="/logout">
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          <span class="user-name"><i class="fa-solid fa-user" aria-hidden="true"></i> {{userDisplayName}}</span>
          <button class="btn btn-outline-secondary btn-sm" type="submit"><i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i> Log out</button>
        </form>
      </header>
      <main class="content admin-content">{{{body}}}</main>
    </div>
  </div>
  {{/authenticated}}
  {{^authenticated}}<main>{{{body}}}</main>{{/authenticated}}
  <script src="/vendor/tagify.js" defer></script>
  <script src="/assets/app.js" defer></script>
</body>
</html>
