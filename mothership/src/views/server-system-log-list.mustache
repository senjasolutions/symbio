<!-- Lists predefined system-level log files accessible on the host (syslog, auth, kern, etc). -->
<nav aria-label="{{#t}}common.breadcrumb{{/t}}"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/servers">{{#t}}nav.servers{{/t}}</a></li><li class="breadcrumb-item"><a href="/servers/{{server.id}}">{{server.displayName}}</a></li><li class="breadcrumb-item active">{{#t}}server.serverLogs.title{{/t}}</li></ol></nav>
<h1 class="h3 mb-1">{{#t}}server.serverLogs.title{{/t}}</h1>
<p class="text-secondary small mb-3">{{#t}}server.serverLogs.description{{/t}}</p>
<section class="card"><div class="table-responsive"><table class="table mb-0"><thead><tr><th>{{#t}}server.serverLogs.logName{{/t}}</th><th class="d-none d-md-table-cell">{{#t}}server.logs.filePath{{/t}}</th><th></th></tr></thead><tbody>{{#sources}}<tr><td><strong>{{displayName}}</strong></td><td class="d-none d-md-table-cell"><code class="small">{{path}}</code></td><td class="text-end"><a class="btn btn-outline-primary btn-sm" href="/servers/{{server.id}}/monitoring/logs/server/view?source={{slug}}">{{#t}}application.detail.view{{/t}}</a></td></tr>{{/sources}}{{^sources}}<tr><td colspan="3" class="text-muted">{{#t}}server.serverLogs.noLogs{{/t}}</td></tr>{{/sources}}</tbody></table></div></section>
